{% comment %}
  grow-with-zenbud-before-wholesale-form.liquid
{% endcomment %}

{{ 'grow-with-zenbud-split.css' | asset_url | stylesheet_tag }}

<div class="grow-with-zenbud grow-with-zenbud--before-wholesale">

    <section class="container-fluid hero-container d-flex flex-column">
        <div class="row header-row">
            <div class="col-12 d-flex justify-content-center justify-content-md-start align-items-center">
                <a href="/" class="logo-link">
                    <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/zbd-footer-logo.png?v=1761123836" alt="ZenBud" class="logo-img">
                </a>
            </div>
        </div>

        <div class="row flex-grow-1">
            <div class="col-12 col-md-6 d-flex flex-column justify-content-between justify-content-md-start hero-content">
                <div>
                    <h1 class="hero-title">
                        <span class="font-light"><img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/grow-with-zenbud-icon.png?v=1773861784" alt="" aria-hidden="true"> GROW</span><br>
                        <span class="font-light">WITH</span> <span class="font-bold">ZENBUD</span>
                    </h1>
                    <p class="hero-paragraph">
                        Join a movement helping people find calm, and build a business doing it. <strong>Choose the partnership path that fits you.</strong>
                    </p>
                </div>
                
                <div class="hero-mobile-spacer flex-grow-1 d-md-none"></div>

                <div class="d-flex align-items-start hero-buttons-wrapper mt-auto mt-md-0 pb-md-0 flex-column">
                    <a href="/pages/wholesale" class="btn-custom btn-orange">Wholesale Partner Program</a>
                    <a href="https://partners.zenbud.health/" class="btn-custom btn-outline">Affiliate Program</a>
                </div>
            </div>
        </div>
    </section>

    <section class="container-fluid partnership-section">
        <div class="row">
            <div class="col-12 d-flex flex-column align-items-center">
                <h2 class="partnership-heading">Which Partnership Is Right For You?</h2>
                <p class="partnership-subheading">
                    Both programs let you share ZenBud with the world, <br><strong><em>but the difference is in how you earn and how you're involved.</em></strong>
                </p>
            </div>
        </div>
        
        <div class="row g-4 mt-2 mt-md-0">
            <div class="col-12 col-md-6">
                <div class="card-custom">
                    <h3 class="card-title">Wholesale Partner</h3>
                    <div class="list-row">
                        <div class="list-label">BEST FOR:</div>
                        <div class="list-value">Practitioners, clinics, wellness centers, chiropractors, biohacking studios</div>
                    </div>
                    <div class="list-row">
                        <div class="list-label">HOW IT WORKS:</div>
                        <div class="list-value">Purchase 5+ units at wholesale pricing and resell directly to your clients or patients</div>
                    </div>
                    <div class="list-row">
                        <div class="list-label">EARNINGS:</div>
                        <div class="list-value">Keep the full retail margin — you set your price</div>
                    </div>
                    <div class="list-row">
                        <div class="list-label">INVENTORY:</div>
                        <div class="list-value">You hold stock</div>
                    </div>
                    <div class="list-row">
                        <div class="list-label">IDEAL IF:</div>
                        <div class="list-value">You have an existing client base and want to offer ZenBud as part of your practice or retail offering</div>
                    </div>
                    <div class="card-spacer"></div>
                    <a href="/pages/wholesale" class="btn-partnership btn-blue-gradient">Become a Wholesale Partner</a>
                </div>
            </div>
            
            <div class="col-12 col-md-6">
                <div class="card-custom">
                    <h3 class="card-title">Affiliate Partner</h3>
                    <div class="list-row">
                        <div class="list-label">BEST FOR:</div>
                        <div class="list-value">Content creators, coaches, influencers, health bloggers, podcasters</div>
                    </div>
                    <div class="list-row">
                        <div class="list-label">HOW IT WORKS:</div>
                        <div class="list-value">Share your unique referral link, earn a commission on every sale you drive</div>
                    </div>
                    <div class="list-row">
                        <div class="list-label">EARNINGS:</div>
                        <div class="list-value">Commission per sale (no inventory needed)</div>
                    </div>
                    <div class="list-row">
                        <div class="list-label">INVENTORY:</div>
                        <div class="list-value">None, ZenBud handles fulfillment</div>
                    </div>
                    <div class="list-row">
                        <div class="list-label">IDEAL IF:</div>
                        <div class="list-value">You have an audience and want to earn passively by recommending ZenBud</div>
                    </div>
                    <div class="card-spacer"></div>
                    <a href="https://partners.zenbud.health/" class="btn-partnership btn-orange-gradient">Join the Affiliate Partner</a>
                </div>
            </div>
        </div>
    </section>

    <section class="container-fluid p-0 wholesale-banner-section" id="wholesale">
        <div class="row g-0">
            <div class="col-12 col-md-6 wholesale-img-col"></div>
            <div class="col-12 col-md-6 wholesale-bg-col d-flex flex-column justify-content-center">
                <div class="wholesale-banner-title-wrap">
                    <h2 class="wholesale-banner-title"><img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/wholesale-icon.png?v=1773801765" alt="" aria-hidden="true" class="wholesale-banner-icon" loading="lazy"> <strong>Wholesale</strong><br>Partner Program</h2>
                </div>
                <p class="wholesale-banner-subtitle">Buy at wholesale. Sell at retail.<br>Keep the margin.</p>
            </div>
        </div>
    </section>

    <section class="container-fluid wholesale-content-section">
        <div class="row">
            <div class="col-12">
                <p class="wholesale-intro-text">
                    Designed for practitioners, clinics, and wellness professionals who want to offer ZenBud directly to their clients. Purchase 5 or more units at a discounted wholesale price and resell them through your practice or storefront.
                </p>
            </div>
        </div>

        <div class="wholesale-features-grid">
            <div class="row g-0">
                <div class="col-12 col-md-6 feature-cell border-bottom-vw border-right-vw mobile-border-bottom">
                    <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/wholesale-pricing_20c91184-778b-4b9d-9273-507eb4d50e22.png?v=1779256594" alt="Wholesale Pricing" class="feature-icon" loading="lazy">
                    <div class="feature-text-content">
                        <h4 class="feature-title">Wholesale Pricing</h4>
                        <p class="feature-desc">Significant discount off retail on orders of 5+ units</p>
                    </div>
                </div>
                
                <div class="col-12 col-md-6 feature-cell border-bottom-vw mobile-border-bottom">
                    <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/practice-ready.png?v=1779256594" alt="Practice-Ready" class="feature-icon" loading="lazy">
                    <div class="feature-text-content">
                        <h4 class="feature-title">Practice-Ready</h4>
                        <p class="feature-desc">Perfect for chiropractic, functional medicine, biohacking, and wellness clinics</p>
                    </div>
                </div>
                
                <div class="col-12 col-md-6 feature-cell border-right-vw mobile-border-bottom">
                    <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/control-fulfillment.png?v=1779256593" alt="You Control Fulfillment" class="feature-icon" loading="lazy">
                    <div class="feature-text-content">
                        <h4 class="feature-title">You Control Fulfillment</h4>
                        <p class="feature-desc">Ship directly to clients or hand-deliver in your practice</p>
                    </div>
                </div>
                
                <div class="col-12 col-md-6 feature-cell">
                    <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/earning-potential.png?v=1779256594" alt="Unlimited Earning Potential" class="feature-icon" loading="lazy">
                    <div class="feature-text-content">
                        <h4 class="feature-title">Unlimited Earning Potential</h4>
                        <p class="feature-desc">The more you sell, the more you make</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4 mt-md-0">
            <div class="col-12 wholesale-cta-area">
                <p class="wholesale-cta-text"><strong>Minimum order:</strong> 5 units. Pricing shared after inquiry.</p>
            </div>
        </div>
    </section>
</div>

