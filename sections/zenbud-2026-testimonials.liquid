{% comment %}
  zenbud-testimonials.liquid
{% endcomment %}

<!-- Swiper CSS (CDN) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100vw;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    overflow: hidden; /* Hide horizontal overflow from swiper bleeding out */
    display: block;
  }

  /* Wavy Background Image */
  #shopify-section-{{ section.id }} .zenbud-testi__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .zenbud-testi__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Main Layout */
  #shopify-section-{{ section.id }} .zenbud-testi__container {
    position: relative;
    z-index: 2;
    width: 90vw;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4.16vw; /* ~80px */
  }

  /* Left Column (Text & Button) */
  #shopify-section-{{ section.id }} .zenbud-testi__left {
    flex: 0 0 20.83vw; /* ~400px width */
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .zenbud-testi__subheading {
    color: {{ section.settings.subheading_color }};
    font-size: 0.73vw; /* ~14px */
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.83vw 0; /* ~16px */
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .zenbud-testi__heading {
    font-size: 1.87vw; /* ~36px */
    line-height: 1.2;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1.04vw 0; /* ~20px */
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .zenbud-testi__text {
    font-size: 0.83vw; /* ~16px */
    line-height: 1.5;
    color: {{ section.settings.text_color }};
    margin: 0 0 1.56vw 0; /* ~30px */
  }

  #shopify-section-{{ section.id }} .zenbud-testi__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    border-radius: 2.6vw; /* ~50px */
    padding: 0.93vw 2.08vw; /* ~18px 40px */
    font-size: 0.78vw; /* ~15px */
    font-weight: 600;
    text-decoration: none;
    border: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .zenbud-testi__button:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  /* Right Column (Swiper) */
  #shopify-section-{{ section.id }} .zenbud-testi__right {
    flex: 1;
    min-width: 0;
    overflow: hidden; /* Clips the slides from going left over the text */
    margin-right: -50vw; /* Extends the bounding box off-screen to the right */
    padding-right: 50vw; /* Keeps layout intact while allowing right-side bleed */
  }

  #shopify-section-{{ section.id }} .zenbud-testi__swiper {
    width: 100%;
    overflow: visible; /* Allows slides to bleed off the right edge of the screen */
  }

  #shopify-section-{{ section.id }} .zenbud-testi__swiper .swiper-slide {
    width: 18.2vw; /* ~350px width per card */
    height: auto; /* Let flex stretch them evenly */
    display: flex;
  }

  /* Card Base Styles */
  #shopify-section-{{ section.id }} .zenbud-testi__card {
    width: 100%;
    border-radius: 1.04vw; /* ~20px */
    aspect-ratio: 3 / 4.2; /* Tall rectangle shape */
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    box-shadow: 0 1.04vw 2.08vw rgba(0,0,0,0.05);
    background: transparent;
  }

  /* Text Card (Mirror Blur) */
  #shopify-section-{{ section.id }} .zenbud-testi__card--text {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(0.25vw) brightness(1);
    -webkit-backdrop-filter: blur(1.56vw) brightness(1.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 2.08vw;
    justify-content: space-between;
  }

  #shopify-section-{{ section.id }} .zenbud-testi__avatar {
    width: 3.12vw; /* ~60px */
    height: 3.12vw; /* ~60px */
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1.56vw; /* ~30px */
  }

  #shopify-section-{{ section.id }} .zenbud-testi__quote {
    font-size: 0.88vw; /* ~17px */
    line-height: 1.5;
    color: #ffffff;
    margin: 0 0 1.56vw 0;
    flex-grow: 1; /* Pushes author to bottom */
  }

  #shopify-section-{{ section.id }} .zenbud-testi__author {
    display: flex;
    align-items: center;
    gap: 0.41vw; /* ~8px */
    font-size: 0.73vw; /* ~14px */
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .zenbud-testi__verified-icon {
    width: 1.04vw; /* ~20px */
    height: 1.04vw; /* ~20px */
    fill: #10B981; /* Green */
    flex-shrink: 0;
  }

  /* Video Card */
  #shopify-section-{{ section.id }} .zenbud-testi__card--video {
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .zenbud-testi__video-el {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .zenbud-testi__video-thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 2;
    transition: opacity 0.3s ease;
  }

  #shopify-section-{{ section.id }} .zenbud-testi__play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 4.16vw; /* ~80px */
    height: 4.16vw; /* ~80px */
    z-index: 3;
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }

  /* Hover Effects for Video Card */
  #shopify-section-{{ section.id }} .zenbud-testi__card--video:hover .zenbud-testi__video-thumb,
  #shopify-section-{{ section.id }} .zenbud-testi__card--video:hover .zenbud-testi__play-btn {
    opacity: 0;
  }
  
  #shopify-section-{{ section.id }} .zenbud-testi__card--video:hover .zenbud-testi__play-btn {
    transform: translate(-50%, -50%) scale(0.9);
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    #shopify-section-{{ section.id }} .zenbud-testi__container {
      flex-direction: column;
      align-items: flex-start;
      gap: 8vw;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__left {
      flex: none;
      width: 100%;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__subheading {
      font-size: 3.5vw;
      margin-bottom: 2vw;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__heading {
      font-size: 7vw;
      margin-bottom: 3vw;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__text {
      font-size: 4vw;
      margin-bottom: 6vw;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__button {
      padding: 4vw 6vw;
      font-size: 3.5vw;
      border-radius: 8vw;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__right {
      width: 100%;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__swiper .swiper-slide {
      width: 75vw; /* Allows the next card to peek onto the screen */
    }
    #shopify-section-{{ section.id }} .zenbud-testi__card {
      border-radius: 5vw;
      aspect-ratio: 3 / 4;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__card--text {
      padding: 6vw;
      backdrop-filter: blur(4vw) brightness(1.1);
      -webkit-backdrop-filter: blur(4vw) brightness(1.1);
    }
    #shopify-section-{{ section.id }} .zenbud-testi__avatar {
      width: 12vw;
      height: 12vw;
      margin-bottom: 4vw;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__quote {
      font-size: 4vw;
      margin-bottom: 4vw;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__author {
      font-size: 3.2vw;
      gap: 1.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__verified-icon {
      width: 4.5vw;
      height: 4.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-testi__play-btn {
      width: 15vw;
      height: 15vw;
    }
  }
</style>

{%- if section.settings.bg_image != blank -%}
  <div class="zenbud-testi__bg">
    {{ section.settings.bg_image | image_url: width: 2400 | image_tag: loading: 'lazy', alt: section.settings.bg_image.alt | default: 'Testimonials background' }}
  </div>
{%- endif -%}

<div class="zenbud-testi__container">
  
  <div class="zenbud-testi__left">
    {%- if section.settings.subheading != blank -%}
      <h3 class="zenbud-testi__subheading">{{ section.settings.subheading | escape }}</h3>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="zenbud-testi__heading">
        {{ section.settings.heading | replace: ' ', '<br>' | replace: '<br>about<br>', ' about ' }}
      </h2>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="zenbud-testi__text">{{ section.settings.text | escape }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '#' }}" class="zenbud-testi__button">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>

  <div class="zenbud-testi__right">
    <div class="swiper zenbud-testi__swiper" id="swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        
        {%- for block in section.blocks -%}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            
            {%- if block.type == 'text_review' -%}
              <div class="zenbud-testi__card zenbud-testi__card--text">
                {%- if block.settings.avatar != blank -%}
                  {{ block.settings.avatar | image_url: width: 120 | image_tag: class: 'zenbud-testi__avatar', loading: 'lazy', alt: block.settings.author }}
                {%- else -%}
                  <img src="{{ 'avatar-placeholder.jpg' | asset_url }}" alt="{{ block.settings.author | escape }}" class="zenbud-testi__avatar" loading="lazy">
                {%- endif -%}
                
                <p class="zenbud-testi__quote">{{ block.settings.quote | escape }}</p>
                
                <div class="zenbud-testi__author">
                  <svg class="zenbud-testi__verified-icon" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  {{ block.settings.author | escape }} | Verified Customer
                </div>
              </div>

            {%- elsif block.type == 'video_review' -%}
              <div class="zenbud-testi__card zenbud-testi__card--video" onmouseenter="this.querySelector('video').play()" onmouseleave="this.querySelector('video').pause()">
                
                {%- if block.settings.video != blank -%}
                  {{ block.settings.video | video_tag: loop: true, muted: true, playsinline: true, class: 'zenbud-testi__video-el' }}
                {%- endif -%}
                
                {%- if block.settings.thumbnail != blank -%}
                  {{ block.settings.thumbnail | image_url: width: 1200 | image_tag: class: 'zenbud-testi__video-thumb', loading: 'lazy', alt: 'Video Thumbnail' }}
                {%- endif -%}

                {%- if block.settings.play_button != blank -%}
                  {{ block.settings.play_button | image_url: width: 160 | image_tag: class: 'zenbud-testi__play-btn', loading: 'lazy', alt: 'Play' }}
                {%- endif -%}
                
              </div>
            {%- endif -%}

          </div>
        {%- endfor -%}

      </div>
    </div>
  </div>

</div>

<!-- Swiper JS Init -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  function initZenbudTestiSwiper{{ section.id | remove: '-' }}() {
    const swiperEl = document.querySelector('#swiper-{{ section.id }}');
    if (!swiperEl) return;

    new Swiper(swiperEl, {
      slidesPerView: 'auto',
      spaceBetween: window.innerWidth * 0.0104, /* ~20px on desktop */
      grabCursor: true,
      breakpoints: {
        750: {
          spaceBetween: window.innerWidth * 0.0156, /* ~30px */
        }
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initZenbudTestiSwiper{{ section.id | remove: '-' }});

  // Re-initialize for Shopify Theme Editor
  if (window.Shopify && window.Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initZenbudTestiSwiper{{ section.id | remove: '-' }}();
      }
    });
  }
</script>

{% schema %}
{
  "name": "ZenBud Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color Fallback",
      "default": "#426BE0"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image",
      "info": "Upload the blue wavy abstract background image here."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 8.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 8.0
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "TESTIMONIALS"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What people love about ZenBud"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description Color",
      "default": "#EAEAEA"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "The best proof is how ZenBud fits into real life, from winding down before bed to resetting after a stressful day."
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Visit ZenBud Community"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "text_review",
      "name": "Text Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Author Avatar"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review Quote",
          "default": "\"As you know, consistency is key to improving and maintaining good mental health. ZenBud makes it simple to stay on track...\""
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Steve N."
        }
      ]
    },
    {
      "type": "video_review",
      "name": "Video Review",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video File",
          "info": "Upload an MP4. Video plays when hovered."
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail Image"
        },
        {
          "type": "image_picker",
          "id": "play_button",
          "label": "Play Button Image Overlay",
          "info": "Optional custom play button image. Will fallback to default asset if blank."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud Testimonials",
      "category": "Home Revamp",
      "blocks": [
        {
          "type": "text_review",
          "settings": {
            "author": "Steve N."
          }
        },
        {
          "type": "video_review"
        },
        {
          "type": "text_review",
          "settings": {
            "author": "Dena N."
          }
        }
      ]
    }
  ]
}
{% endschema %}