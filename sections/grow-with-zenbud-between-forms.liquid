{{ 'grow-with-zenbud-split.css' | asset_url | stylesheet_tag }}

<div class="grow-with-zenbud grow-with-zenbud--between-forms">
    <section class="container-fluid p-0 affiliate-banner-section">
        <div class="row g-0">
            <div class="col-12 col-md-6 affiliate-img-col"><img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/affiliate-program.webp?v=1779256714" alt="ZenBud affiliate partner" loading="lazy"></div>
            <div class="col-12 col-md-6 affiliate-bg-col d-flex flex-column justify-content-center">
                <div class="affiliate-banner-title-wrap">
                    <h2 class="affiliate-banner-title"><img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/affiliate-program-icon.png?v=1773802627" alt="" aria-hidden="true" class="affiliate-banner-icon" loading="lazy"> <strong>Affiliate</strong> Program</h2>
                </div>
                <p class="affiliate-banner-subtitle">Share ZenBud. Earn on every sale.<br>No inventory needed.</p>
            </div>
        </div>
    </section>

    <section class="container-fluid affiliate-content-section">
        <div class="row">
            <div class="col-12">
                <p class="affiliate-intro-text">
                    Perfect for coaches, content creators, health influencers, and wellness advocates. Sign up, get your unique referral link, and earn a commission every time someone purchases through it. ZenBud handles everything else.
                </p>
            </div>
        </div>

        <div class="affiliate-features-grid">
            <div class="row g-0">
                <div class="col-12 col-md-6 feature-cell border-bottom-vw border-right-vw mobile-border-bottom">
                    <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/referral-link.png?v=1779256868" alt="Unique Referral Link" class="feature-icon" loading="lazy">
                    <div class="feature-text-content">
                        <h4 class="feature-title">Unique Referral Link</h4>
                        <p class="feature-desc">Your personal link tracks every sale you drive</p>
                    </div>
                </div>
                
                <div class="col-12 col-md-6 feature-cell border-bottom-vw mobile-border-bottom">
                    <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/wholesale-pricing_20c91184-778b-4b9d-9273-507eb4d50e22.png?v=1779256594" alt="Commission Per Sale" class="feature-icon" loading="lazy">
                    <div class="feature-text-content">
                        <h4 class="feature-title">Commission Per Sale</h4>
                        <p class="feature-desc">Earn every time someone buys through your link</p>
                    </div>
                </div>
                
                <div class="col-12 col-md-6 feature-cell border-right-vw mobile-border-bottom">
                    <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/zero-fulfillment.png?v=1779256868" alt="Zero Fulfillment" class="feature-icon" loading="lazy">
                    <div class="feature-text-content">
                        <h4 class="feature-title">Zero Fulfillment</h4>
                        <p class="feature-desc">ZenBud ships directly to your referrals</p>
                    </div>
                </div>
                
                <div class="col-12 col-md-6 feature-cell">
                    <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/real-time.png?v=1779256868" alt="Real-Time Dashboard" class="feature-icon" loading="lazy">
                    <div class="feature-text-content">
                        <h4 class="feature-title">Real-Time Dashboard</h4>
                        <p class="feature-desc">Track clicks, conversions, and earnings via Inflection</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4 mt-md-0">
            <div class="col-12 affiliate-cta-area">
                <p class="affiliate-cta-text"><strong>Powered by Inflection.</strong> You'll receive login credentials within 2 business days of approval.</p>
            </div>
        </div>
    </section>
</div>

