{% comment %}
  zenbud-blog-template.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    width: 100vw;
    display: block;
    background-color: {{ section.settings.content_bg_color }};
  }

  /* =========================================
     HERO BANNER
     ========================================= */
  #shopify-section-{{ section.id }} .zbd-blog-hero {
    position: relative;
    width: 100%;
    background-color: {{ section.settings.hero_bg_color }};
    padding-top: {{ section.settings.hero_padding_top }}vw;
    padding-bottom: {{ section.settings.hero_padding_bottom }}vw;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .zbd-blog-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    pointer-events: none;
    opacity: {{ section.settings.bg_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .zbd-blog-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zbd-blog-hero__title {
    font-size: 2.5vw;
    /* ~48px */
    font-weight: 700;
    text-transform: uppercase;
    color: {{ section.settings.title_color }};
    margin: 0;
    text-align: center;
    letter-spacing: 0.02em;
    padding: 0 4vw;
  }

  #shopify-section-{{ section.id }} .zbd-blog-hero__subtitle {
    font-size: 1.25vw;
    font-weight: 400;
    color: {{ section.settings.subtitle_color }};
    margin: 1vw 0 0 0;
    text-align: center;
    padding: 0 4vw;
  }

  /* =========================================
     CONTENT & BLOCKS AREA
     ========================================= */
  #shopify-section-{{ section.id }} .zbd-blog-content {
    width: 75vw;
    max-width: 75vw; 
    margin: 0 auto;
    padding-top: {{ section.settings.content_padding_top }}vw;
    padding-bottom: {{ section.settings.content_padding_bottom }}vw;
    color: {{ section.settings.text_color }};
  }

  /* Rich Text Block Typography */
  #shopify-section-{{ section.id }} .zbd-block-richtext h1,
  #shopify-section-{{ section.id }} .zbd-block-richtext h2,
  #shopify-section-{{ section.id }} .zbd-block-richtext h3,
  #shopify-section-{{ section.id }} .zbd-block-richtext h4,
  #shopify-section-{{ section.id }} .zbd-block-richtext h5,
  #shopify-section-{{ section.id }} .zbd-block-richtext h6 {
    color: {{ section.settings.heading_color }};
    font-weight: 700;
    margin-top: 2.5vw;
    margin-bottom: 1vw;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .zbd-block-richtext h1 { font-size: 2.08vw; } /* ~40px */
  #shopify-section-{{ section.id }} .zbd-block-richtext h2 { font-size: 1.66vw; } /* ~32px */
  #shopify-section-{{ section.id }} .zbd-block-richtext h3 { font-size: 1.25vw; } /* ~24px */
  #shopify-section-{{ section.id }} .zbd-block-richtext h4 { font-size: 1.04vw; } /* ~20px */

  #shopify-section-{{ section.id }} .zbd-block-richtext p,
  #shopify-section-{{ section.id }} .zbd-block-richtext li {
    font-size: 0.93vw;
    /* ~18px */
    line-height: 1.6;
    margin-top: 0;
    margin-bottom: 1.5vw;
  }

  #shopify-section-{{ section.id }} .zbd-block-richtext ul,
  #shopify-section-{{ section.id }} .zbd-block-richtext ol {
    margin-bottom: 1.5vw;
    padding-left: 2vw;
  }

  #shopify-section-{{ section.id }} .zbd-block-richtext a {
    color: {{ section.settings.link_color }};
    text-decoration: underline;
    transition: opacity 0.2s;
  }

  #shopify-section-{{ section.id }} .zbd-block-richtext a:hover {
    opacity: 0.7;
  }

  /* =========================================
     INLINE MENU (CATEGORIES)
     ========================================= */
  #shopify-section-{{ section.id }} .blog-categories {
    margin-bottom: 2.5vw;
  }
  
  #shopify-section-{{ section.id }} .blog-categories-list {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5vw;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  #shopify-section-{{ section.id }} .blog-categories-list a {
    text-decoration: none;
    color: #fff;
    background-color: #374151;
    font-size: 0.93vw;
    font-weight: 600;
    padding: 0.75vw 2vw;
    border-radius: 2vw;
    transition: color 0.2s, opacity 0.2s;
  }
  
  #shopify-section-{{ section.id }} .blog-categories-list a:hover {
    opacity: 0.7;
  }
  
  #shopify-section-{{ section.id }} .blog-categories-list a.active-link {
    color: #fff;
    background-color: #3a78f2;
  }

  /* =========================================
     ARTICLE GRID
     ========================================= */
  #shopify-section-{{ section.id }} .zbd-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5vw;
    margin-top: 3vw;
  }

  #shopify-section-{{ section.id }} .zbd-blog-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .zbd-blog-card:hover {
    transform: translateY(-4px);
  }

  #shopify-section-{{ section.id }} .zbd-blog-card__image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 1vw;
    margin-bottom: 1.5vw;
    background-color: #f3f4f6;
  }

  #shopify-section-{{ section.id }} .zbd-blog-card__title {
    font-size: 1.25vw;
    /* ~24px */
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.5vw 0;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .zbd-blog-card__excerpt {
    font-size: 0.93vw;
    /* ~18px */
    color: {{ section.settings.text_color }};
    opacity: 0.85;
    line-height: 1.5;
    margin: 0;
  }

  /* Pagination */
  #shopify-section-{{ section.id }} .zbd-pagination {
    margin-top: 4vw;
    display: flex;
    justify-content: center;
    gap: 0.5vw;
  }
  
  #shopify-section-{{ section.id }} .zbd-pagination span,
  #shopify-section-{{ section.id }} .zbd-pagination a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5vw;
    height: 2.5vw;
    border-radius: 0.3vw;
    text-decoration: none;
    font-size: 0.93vw;
    color: {{ section.settings.text_color }};
    border: 1px solid rgba(0,0,0,0.1);
  }

  #shopify-section-{{ section.id }} .zbd-pagination .current {
    background-color: {{ section.settings.link_color }};
    color: #ffffff;
    border-color: {{ section.settings.link_color }};
  }

  /* =========================================
     MOBILE RESPONSIVE
     ========================================= */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .zbd-blog-hero {
      padding-top: calc({{ section.settings.hero_padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.hero_padding_bottom }}vw * 3);
    }

    #shopify-section-{{ section.id }} .zbd-blog-hero__title {
      font-size: 8vw;
    }

    #shopify-section-{{ section.id }} .zbd-blog-hero__subtitle {
      font-size: 4vw;
      margin-top: 2vw;
    }

    #shopify-section-{{ section.id }} .zbd-blog-content {
      width: 90vw;
      max-width: 90vw;
      padding-top: calc({{ section.settings.content_padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.content_padding_bottom }}vw * 3);
    }

    /* Blocks Typography Mobile */
    #shopify-section-{{ section.id }} .zbd-block-richtext h1,
    #shopify-section-{{ section.id }} .zbd-block-richtext h2,
    #shopify-section-{{ section.id }} .zbd-block-richtext h3,
    #shopify-section-{{ section.id }} .zbd-block-richtext h4,
    #shopify-section-{{ section.id }} .zbd-block-richtext h5,
    #shopify-section-{{ section.id }} .zbd-block-richtext h6 {
      font-size: 6vw;
    }
    #shopify-section-{{ section.id }} .zbd-block-richtext h1 { font-size: 8vw; }
    #shopify-section-{{ section.id }} .zbd-block-richtext h2 { font-size: 7vw; }
    #shopify-section-{{ section.id }} .zbd-block-richtext p,
    #shopify-section-{{ section.id }} .zbd-block-richtext li {
      font-size: 3.5vw;
    }

    /* Menu Mobile */
    #shopify-section-{{ section.id }} .blog-categories-list {
      gap: 3vw;
    }
    #shopify-section-{{ section.id }} .blog-categories-list a {
      font-size: 3.5vw;
    }

    /* Blog Grid Mobile */
    #shopify-section-{{ section.id }} .zbd-blog-grid {
      grid-template-columns: 1fr;
      gap: 8vw;
      margin-top: 6vw;
    }
    #shopify-section-{{ section.id }} .zbd-blog-card__image {
      border-radius: 3vw;
      margin-bottom: 3vw;
    }
    #shopify-section-{{ section.id }} .zbd-blog-card__title {
      font-size: 6vw;
      margin-bottom: 2vw;
    }
    #shopify-section-{{ section.id }} .zbd-blog-card__excerpt {
      font-size: 4vw;
    }
    #shopify-section-{{ section.id }} .zbd-pagination {
      margin-top: 8vw;
      gap: 2vw;
    }
    #shopify-section-{{ section.id }} .zbd-pagination span,
    #shopify-section-{{ section.id }} .zbd-pagination a {
      min-width: 10vw;
      height: 10vw;
      font-size: 4vw;
      border-radius: 1.5vw;
    }
  }
</style>

<div class="zbd-blog-hero">
  {%- if section.settings.bg_image != blank -%}
    {{ section.settings.bg_image | image_url: width: 2400 | image_tag: class: 'zbd-blog-hero__bg', loading: 'eager', alt: blog.title }}
  {%- endif -%}

  <div class="zbd-blog-hero__content">
    <h1 class="zbd-blog-hero__title">
      {%- if section.settings.override_title != blank -%}
        {{ section.settings.override_title | escape }}
      {%- else -%}
        {{ blog.title | escape }}
      {%- endif -%}
    </h1>
    
    {%- if section.settings.subtitle != blank -%}
      <p class="zbd-blog-hero__subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}
  </div>
</div>

<div class="zbd-blog-content">
  
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'rich_text' -%}
        <div class="zbd-block-richtext" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
        </div>
    {%- endcase -%}
  {%- endfor -%}

  {%- if section.settings.show_articles -%}

    <nav class="blog-categories flex justify-center">
      <ul class="blog-categories-list list-menu--inline">
        <li>
          <a href="{{ blog.url }}" class="{% if current_tags == blank %}active-link{% endif %}">
            All
          </a>
        </li>
        <li>
          <a href="{{ blog.url }}/tagged/blogs" class="{% if current_tags contains 'blogs' %}active-link{% endif %}">
            Blogs
          </a>
        </li>
        <li>
          <a href="{{ blog.url }}/tagged/guides" class="{% if current_tags contains 'guides' %}active-link{% endif %}">
            Guides
          </a>
        </li>
        <li>
          <a href="{{ blog.url }}/tagged/events" class="{% if current_tags contains 'events' %}active-link{% endif %}">
            Events
          </a>
        </li>
        <li>
          <a href="{{ blog.url }}/tagged/media" class="{% if current_tags contains 'media' %}active-link{% endif %}">
            Media
          </a>
        </li>
      </ul>
    </nav>

    {%- paginate blog.articles by section.settings.articles_per_page -%}
      
      <div class="zbd-blog-grid">
        {%- for article in blog.articles -%}
          <a href="{{ article.url }}" class="zbd-blog-card">
            
            {%- if article.image -%}
              {{ article.image | image_url: width: 800 | image_tag: class: 'zbd-blog-card__image', loading: 'lazy', alt: article.title }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'zbd-blog-card__image placeholder-svg' }}
            {%- endif -%}
            
            <h3 class="zbd-blog-card__title">{{ article.title | escape }}</h3>
            
            <div class="zbd-blog-card__excerpt">
              {%- if article.excerpt.size > 0 -%}
                {{ article.excerpt | strip_html | truncatewords: 25 }}
              {%- else -%}
                {{ article.content | strip_html | truncatewords: 25 }}
              {%- endif -%}
            </div>

          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="zbd-pagination">
          {{ paginate | default_pagination: next: '→', previous: '←' }}
        </div>
      {%- endif -%}

    {%- endpaginate -%}
  {%- endif -%}

</div>

{% schema %}
{
  "name": "ZenBud Blog Template",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Hero Banner Settings"
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Hero Background Color",
      "default": "#3A78F2"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Hero Background Image"
    },
    {
      "type": "range",
      "id": "bg_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Image Opacity",
      "default": 100
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "override_title",
      "label": "Custom Title (Optional)",
      "info": "Leave blank to automatically use the actual Blog Title."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "info": "Optional text to display below the title."
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "hero_padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Hero Padding Top (Desktop)",
      "default": 6.0
    },
    {
      "type": "range",
      "id": "hero_padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Hero Padding Bottom (Desktop)",
      "default": 6.0
    },
    {
      "type": "header",
      "content": "Blog Layout Settings"
    },
    {
      "type": "checkbox",
      "id": "show_articles",
      "label": "Show Articles Grid",
      "default": true
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 3,
      "max": 24,
      "step": 3,
      "label": "Articles per page",
      "default": 9
    },
    {
      "type": "color",
      "id": "content_bg_color",
      "label": "Content Area Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Headings Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#374151"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link & Pagination Color",
      "default": "#3A78F2"
    },
    {
      "type": "range",
      "id": "content_padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Content Padding Top (Desktop)",
      "default": 6.0
    },
    {
      "type": "range",
      "id": "content_padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Content Padding Bottom (Desktop)",
      "default": 8.0
    }
  ],
  "blocks": [
    {
      "type": "rich_text",
      "name": "Rich Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add a description or intro text above your blog posts.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud Blog Template",
      "category": "ZenBud Base"
    }
  ]
}
{% endschema %}