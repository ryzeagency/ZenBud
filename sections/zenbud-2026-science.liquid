{% comment %}
  zenbud-science.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100vw;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .zenbud-science__container {
    width: 90vw; /* 90% container width as requested */
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    gap: 4.16vw; /* 80px */
    align-items: center;
    justify-content: space-between;
  }

  #shopify-section-{{ section.id }} .zenbud-science__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1 1 0%;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .zenbud-science__subheading {
    color: {{ section.settings.accent_color }};
    font-size: 0.73vw; /* 14px */
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.83vw 0; /* 16px */
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .zenbud-science__heading {
    font-size: 1.87vw; /* 36px */
    line-height: 1.3;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1.56vw 0; /* 30px */
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .zenbud-science__heading strong {
    display: block;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .zenbud-science__text {
    font-size: 0.83vw; /* 16px */
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin: 0 0 1.25vw 0; /* 24px */
    max-width: 90%;
  }

  #shopify-section-{{ section.id }} .zenbud-science__metrics {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    gap: 1.04vw; /* 20px */
    border: 1px solid {{ section.settings.metrics_border_color }};
    border-radius: 0.62vw; /* 12px */
    padding: 1.25vw 1.56vw; /* 24px 30px */
    margin: 1.56vw 0 2.08vw 0; /* 30px 0 40px 0 */
  }

  #shopify-section-{{ section.id }} .zenbud-science__metric {
    flex: 1 1 0%;
  }

  #shopify-section-{{ section.id }} .zenbud-science__metric-title {
    font-size: 0.93vw; /* 18px */
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.41vw 0; /* 8px */
  }

  #shopify-section-{{ section.id }} .zenbud-science__metric-text {
    font-size: 0.62vw; /* 12px */
    line-height: 1.4;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  #shopify-section-{{ section.id }} .zenbud-science__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.accent_color }};
    color: #ffffff;
    border-radius: 2.6vw; /* 50px */
    padding: 0.93vw 2.08vw; /* 18px 40px */
    font-size: 0.73vw; /* 14px */
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: none;
    transition: opacity 0.3s ease;
    width: fit-content;
  }

  #shopify-section-{{ section.id }} .zenbud-science__button:hover {
    opacity: 0.9;
  }

  #shopify-section-{{ section.id }} .zenbud-science__media {
    flex: 1 1 0%;
    width: 100%;
    aspect-ratio: 1 / 1; /* Square video as requested */
    overflow: hidden;
    position: relative;
    border-radius: 0.41vw; /* 8px */
    background-color: #111;
  }

  #shopify-section-{{ section.id }} .zenbud-science__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  #shopify-section-{{ section.id }} .zenbud-science__video-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #333;
    background-color: #050505;
  }

  /* Responsive styling for readability on mobile devices */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    #shopify-section-{{ section.id }} .zenbud-science__container {
      flex-direction: column;
      gap: 8vw;
    }
    #shopify-section-{{ section.id }} .zenbud-science__subheading {
      font-size: 3.5vw;
      margin-bottom: 2vw;
    }
    #shopify-section-{{ section.id }} .zenbud-science__heading {
      font-size: 7vw;
      margin-bottom: 4vw;
    }
    #shopify-section-{{ section.id }} .zenbud-science__text {
      font-size: 3.5vw;
      margin-bottom: 4vw;
      max-width: 100%;
    }
    #shopify-section-{{ section.id }} .zenbud-science__metrics {
      flex-direction: column;
      gap: 4vw;
      border-radius: 3vw;
      padding: 5vw;
      margin: 4vw 0 6vw 0;
    }
    #shopify-section-{{ section.id }} .zenbud-science__metric-title {
      font-size: 4.5vw;
      margin-bottom: 1vw;
    }
    #shopify-section-{{ section.id }} .zenbud-science__metric-text {
      font-size: 3.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-science__button {
      width: 100%;
      border-radius: 8vw;
      padding: 3.5vw 6vw;
      font-size: 3.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-science__media {
      border-radius: 2vw;
    }
  }
</style>

<div class="zenbud-science__container">
  <div class="zenbud-science__content">
    {%- if section.settings.subheading != blank -%}
      <h3 class="zenbud-science__subheading h6">{{ section.settings.subheading | escape }}</h3>
    {%- endif -%}

    {%- if section.settings.heading_bold != blank or section.settings.heading_regular != blank -%}
      <h2 class="zenbud-science__heading h2">
        {%- if section.settings.heading_bold != blank -%}
          <strong>{{ section.settings.heading_bold | escape }}</strong>
        {%- endif -%}
        {%- if section.settings.heading_regular != blank -%}
          {{ section.settings.heading_regular | escape }}
        {%- endif -%}
      </h2>
    {%- endif -%}

    {%- if section.settings.text_1 != blank -%}
      <p class="zenbud-science__text paragraph">{{ section.settings.text_1 | escape }}</p>
    {%- endif -%}

    {%- if section.settings.text_2 != blank -%}
      <p class="zenbud-science__text paragraph">{{ section.settings.text_2 | escape }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="zenbud-science__metrics">
        {%- for block in section.blocks -%}
          <div class="zenbud-science__metric" {{ block.shopify_attributes }}>
            <p class="zenbud-science__metric-title">{{ block.settings.title | escape }}</p>
            <p class="zenbud-science__metric-text">{{ block.settings.text | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '#' }}" class="zenbud-science__button">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>

  <div class="zenbud-science__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'zenbud-science__video', playsinline: true }}
    {%- else -%}
      <div class="zenbud-science__video-placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "ZenBud Science Split",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#c4c4c4"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent & Button Color",
      "default": "#2E62DB"
    },
    {
      "type": "color",
      "id": "metrics_border_color",
      "label": "Metrics Border Color",
      "default": "rgba(46, 98, 219, 0.3)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 5
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 5
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "THE SCIENCE"
    },
    {
      "type": "text",
      "id": "heading_bold",
      "label": "Heading (Bold part)",
      "default": "The Vagus Nerve:"
    },
    {
      "type": "text",
      "id": "heading_regular",
      "label": "Heading (Regular part)",
      "default": "Your Body's Built-In Reset Button."
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "First Paragraph",
      "default": "The vagus nerve runs from your brainstem through your heart, lungs, and gut, helping regulate stress and recovery. Most people never learn to work with it."
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Second Paragraph",
      "default": "ZenBud targets its auricular branch, the only part accessible from outside the body, using focused ultrasound to help support vagal tone over time."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "EXPLORE THE SCIENCE"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Media Settings"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Square Video",
      "info": "Upload a square video. It will autoplay and loop."
    }
  ],
  "blocks": [
    {
      "type": "metric",
      "name": "Metric",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Metric Title",
          "default": "5 Mins ~"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Metric Description",
          "default": "Minimum session to feel the shift"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud Science Split",
      "category": "Home Revamp",
      "blocks": [
        {
          "type": "metric",
          "settings": {
            "title": "5 Mins ~",
            "text": "Minimum session to feel the shift"
          }
        },
        {
          "type": "metric",
          "settings": {
            "title": "Deeper sleep",
            "text": "Reported by most users within the first week"
          }
        },
        {
          "type": "metric",
          "settings": {
            "title": "↑ HRV",
            "text": "Measurable in most users within first session"
          }
        }
      ]
    }
  ]
}
{% endschema %}