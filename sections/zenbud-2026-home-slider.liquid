{% comment %}
  zenbud-stage-carousel.liquid
{% endcomment %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<style>
  /* ---------- Section base ---------- */
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100vw;
    display: block;
  }

  #shopify-section-{{ section.id }} .zenbud-hero {
    padding: 5vw 0 10vw;
    background: #ffffff;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .zenbud-heading {
    text-align: center;
    max-width: 37.5vw; /* 720px */
    margin: 0 auto 2.08vw; /* 0 auto 40px */
    padding: 0 1.04vw; /* 0 20px */
  }

  #shopify-section-{{ section.id }} .zenbud-heading h2 {
    font-size: 1.45vw; /* 28px */
    font-weight: 500;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.52vw; /* 10px */
    letter-spacing: -0.01em;
  }

  #shopify-section-{{ section.id }} .zenbud-heading h2 em {
    font-style: italic;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .zenbud-heading p {
    font-size: 0.78vw; /* 15px */
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  /* ---------- Stage (slider + person + tabs) ---------- */
  #shopify-section-{{ section.id }} .zenbud-stage {
    position: relative;
    width: 90vw; /* Using 90vw container standard */
    max-width: 72.91vw; /* 1400px constraint from original mockup */
    margin: 0 auto;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .zenbud-swiper {
    overflow: visible !important;
  }

  #shopify-section-{{ section.id }} .zenbud-swiper .swiper-slide {
    width: 85%;
    max-width: 52.08vw; /* 1000px */
    aspect-ratio: 17 / 10;
    border-radius: 1.3vw; /* 25px */
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
  }

  /* Inner image — oversized so parallax shift can't reveal edges */
  #shopify-section-{{ section.id }} .zenbud-swiper .slide-bg {
    position: absolute;
    top: 0;
    height: 100%;
    width: 140%;
    left: -20%;
  }

  #shopify-section-{{ section.id }} .zenbud-swiper .slide-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 1.3vw; /* 25px */
  }

  /* ---------- Person cutout (layered on top, doesn't move) ---------- */
  #shopify-section-{{ section.id }} .zenbud-person-wrap {
    position: absolute;
    bottom: -2.6vw; /* -50px */
    left: 50%;
    transform: translateX(-50%);
    width: 75%;
    max-width: 44.27vw; /* 850px */
    aspect-ratio: 16 / 10;
    pointer-events: none;
    z-index: 5;
    overflow: hidden;
    border-radius: 0.93vw; /* 18px */
  }

  #shopify-section-{{ section.id }} .zenbud-person-wrap img {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    height: 100%;
    width: auto;
    object-fit: contain;
    object-position: bottom center;
  }

  /* ---------- Tabs ---------- */
  #shopify-section-{{ section.id }} .zenbud-tabs {
    position: absolute;
    bottom: -4.68vw; /* -90px */
    left: 50%;
    transform: translateX(-50%);
    background: rgba(235, 235, 235, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 52vw; /* 999px equivalent */
    padding: 0.52vw 1.45vw; /* 10px 28px */
    display: flex;
    gap: 1.66vw; /* 32px */
    z-index: 10;
    box-shadow: 0 0.2vw 1.04vw rgba(0,0,0,0.06);
  }

  #shopify-section-{{ section.id }} .zenbud-tabs .tab {
    background: none;
    border: none;
    padding: 0.52vw 1.56vw; /* 10px 30px */
    font-size: 0.73vw; /* 14px */
    color: #555;
    cursor: pointer;
    font-weight: 500;
    position: relative;
    transition: color 0.25s ease;
    font-family: inherit;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .zenbud-tabs .tab:hover { 
    color: #111; 
  }

  #shopify-section-{{ section.id }} .zenbud-tabs .tab.active {
    color: #000;
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .zenbud-tabs .tab.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1.5px;
    background: #000;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .zenbud-hero {
      padding: 8vw 0 15vw;
    }
    #shopify-section-{{ section.id }} .zenbud-heading {
      max-width: 80vw;
      margin-bottom: 6vw;
    }
    #shopify-section-{{ section.id }} .zenbud-heading h2 { 
      font-size: 4vw; 
    }
    #shopify-section-{{ section.id }} .zenbud-heading p { 
      font-size: 2vw; 
    }
    #shopify-section-{{ section.id }} .zenbud-stage {
      max-width: 100%;
    }
    #shopify-section-{{ section.id }} .zenbud-swiper .swiper-slide,
    #shopify-section-{{ section.id }} .zenbud-person-wrap {
      width: 82%;
      max-width: none;
      aspect-ratio: 4 / 5;
    }
    #shopify-section-{{ section.id }} .zenbud-person-wrap {
      bottom: -4vw;
      border-radius: 2vw;
    }
    #shopify-section-{{ section.id }} .zenbud-tabs {
      gap: 2vw;
      padding: 1vw 2vw;
      bottom: -8vw;
    }
    #shopify-section-{{ section.id }} .zenbud-tabs .tab { 
      font-size: 1.8vw; 
      padding: 1.5vw 3vw;
    }
  }

  @media (max-width: 500px) {
    #shopify-section-{{ section.id }} .zenbud-heading h2 { 
      font-size: 6vw; 
    }
    #shopify-section-{{ section.id }} .zenbud-heading p { 
      font-size: 3.5vw; 
    }
    #shopify-section-{{ section.id }} .zenbud-swiper .swiper-slide, 
    #shopify-section-{{ section.id }} .zenbud-person-wrap {
      width: 100%;
      aspect-ratio: 12/9;
    }
    #shopify-section-{{ section.id }} .zenbud-tabs {
      gap: 3vw;
      padding: 2vw 3.5vw;
      bottom: -12vw;
    }
    #shopify-section-{{ section.id }} .zenbud-tabs .tab { 
      font-size: 3vw; 
      padding: 2.5vw 4vw;
    }
    #shopify-section-{{ section.id }} .zenbud-person-wrap {
      width: 85%;
      bottom: -5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-person-wrap img {
      width: 80%;
    }
  }
</style>

<div class="zenbud-hero">
  <div class="zenbud-heading">
    {%- if section.settings.heading != blank -%}
      <h2>{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="paragraph">{{ section.settings.text | escape }}</p>
    {%- endif -%}
  </div>

  <div class="zenbud-stage">

    <div class="swiper zenbud-swiper" id="swiper-{{ section.id }}">
      <div class="swiper-wrapper">

        {%- if section.blocks.size > 0 -%}
          {%- assign last_block = section.blocks | last -%}
          <div class="swiper-slide" aria-hidden="true">
            <div class="slide-bg" data-swiper-parallax="-150">
              {%- if last_block.settings.image != blank -%}
                {{ last_block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
              {%- else -%}
                <img src="{{ 'commute.jpg' | asset_url }}" alt="Fallback Clone Left" loading="lazy">
              {%- endif -%}
            </div>
          </div>

          {%- for block in section.blocks -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <div class="slide-bg" data-swiper-parallax="-150">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.title }}
                {%- else -%}
                  {%- capture fallback_img -%}
                    {%- case forloop.index -%}
                      {%- when 1 -%}airport.jpg
                      {%- when 2 -%}home.jpg
                      {%- when 3 -%}work.jpg
                      {%- else -%}commute.jpg
                    {%- endcase -%}
                  {%- endcapture -%}
                  <img src="{{ fallback_img | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy">
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}

          {%- assign first_block = section.blocks | first -%}
          <div class="swiper-slide" aria-hidden="true">
            <div class="slide-bg" data-swiper-parallax="-150">
              {%- if first_block.settings.image != blank -%}
                {{ first_block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
              {%- else -%}
                <img src="{{ 'airport.jpg' | asset_url }}" alt="Fallback Clone Right" loading="lazy">
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>

    <div class="zenbud-person-wrap">
      {%- if section.settings.foreground_image != blank -%}
        {{ section.settings.foreground_image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
      {%- else -%}
        <img src="{{ 'personwithheadphones.webp' | asset_url }}" alt="Person with headphones" loading="lazy">
      {%- endif -%}
    </div>

    <div class="zenbud-tabs">
      {%- for block in section.blocks -%}
        <button class="tab {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index }}" {{ block.shopify_attributes }}>
          {{ block.settings.title | escape }}
        </button>
      {%- endfor -%}
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  function initZenbudStage{{ section.id | remove: '-' }}() {
    const sectionId = '{{ section.id }}';
    const sectionEl = document.getElementById('shopify-section-' + sectionId);
    if (!sectionEl) return;

    const swiperContainer = sectionEl.querySelector('.zenbud-swiper');
    const realSlideCount = {{ section.blocks.size | default: 0 }};
    
    if (swiperContainer && realSlideCount > 0) {
      const zenbudSwiper = new Swiper(swiperContainer, {
        slidesPerView: 'auto',
        centeredSlides: true,
        spaceBetween: 10,
        parallax: true,
        speed: 1000,
        initialSlide: 1, // start on first real slide (index 1)
        grabCursor: true,
        observer: true,
        observeParents: true,
        observeSlideChildren: true,
        breakpoints: {
          900: {
            spaceBetween: 75, // desktop gap
          },
        },
      });

      // Force recalc after images load
      const slideImages = swiperContainer.querySelectorAll('img');
      let loaded = 0;
      slideImages.forEach(img => {
        if (img.complete) {
          loaded++;
        } else {
          img.addEventListener('load', () => {
            loaded++;
            if (loaded === slideImages.length) zenbudSwiper.update();
          });
        }
      });
      if (loaded === slideImages.length) zenbudSwiper.update();
      setTimeout(() => zenbudSwiper.update(), 300);

      // Tabs click listener
      const tabs = sectionEl.querySelectorAll('.zenbud-tabs .tab');
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          zenbudSwiper.slideTo(parseInt(tab.dataset.index, 10));
        });
      });

      // Manual infinite loop hack synchronization
      zenbudSwiper.on('transitionEnd', () => {
        const idx = zenbudSwiper.activeIndex;
        if (idx === 0) {
          // Left clone -> jump to last real slide
          zenbudSwiper.slideTo(realSlideCount, 0, false);
        } else if (idx === realSlideCount + 1) {
          // Right clone -> jump to first real slide
          zenbudSwiper.slideTo(1, 0, false);
        }
      });

      // Keep active tab in sync
      zenbudSwiper.on('slideChange', () => {
        tabs.forEach(t => t.classList.remove('active'));
        const idx = zenbudSwiper.activeIndex;
        let tabIdx;
        
        if (idx === 0) {
          tabIdx = realSlideCount - 1; // Left clone corresponds to last tab
        } else if (idx === realSlideCount + 1) {
          tabIdx = 0; // Right clone corresponds to first tab
        } else {
          tabIdx = idx - 1; // Real slides
        }
        
        if (tabs[tabIdx]) tabs[tabIdx].classList.add('active');
      });
    }
  }

  // Initialize on load
  document.addEventListener('DOMContentLoaded', initZenbudStage{{ section.id | remove: '-' }});
  
  // Re-initialize for Shopify Theme Editor
  if (window.Shopify && window.Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initZenbudStage{{ section.id | remove: '-' }}();
      }
    });
  }
</script>

{% schema %}
{
  "name": "ZenBud Stage Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#555555"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "The World Doesn't Pause. <em>Now You Can.</em>"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Description text",
      "default": "Most wellness tools need the right conditions. ZenBud works in the wrong ones."
    },
    {
      "type": "image_picker",
      "id": "foreground_image",
      "label": "Foreground Subject Image",
      "info": "Image that sits in front of the carousel (e.g. person wearing headphones)."
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Carousel Slide",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Name",
          "default": "Location"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud Stage Carousel",
      "category": "Home Revamp",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "title": "Airport"
          }
        },
        {
          "type": "slide",
          "settings": {
            "title": "Home"
          }
        },
        {
          "type": "slide",
          "settings": {
            "title": "Work"
          }
        },
        {
          "type": "slide",
          "settings": {
            "title": "Commute"
          }
        }
      ]
    }
  ]
}
{% endschema %}