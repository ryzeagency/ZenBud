{% comment %}
  zenbud-article-template.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    width: 100vw;
    display: block;
    background-color: {{ section.settings.content_bg_color }};
  }

  /* =========================================
     HERO BANNER
     ========================================= */
  #shopify-section-{{ section.id }} .zbd-article-hero {
    position: relative;
    width: 100%;
    background-color: {{ section.settings.hero_bg_color }};
    padding-top: {{ section.settings.hero_padding_top }}vw;
    padding-bottom: {{ section.settings.hero_padding_bottom }}vw;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
  }

  /* Background Image */
  #shopify-section-{{ section.id }} .zbd-article-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    pointer-events: none;
    opacity: {{ section.settings.bg_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .zbd-article-hero__title {
    position: relative;
    z-index: 2;
    font-size: 2.5vw; /* ~48px */
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 1vw 0;
    letter-spacing: 0.02em;
    padding: 0 4vw;
    max-width: 80vw;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .zbd-article-hero__meta {
    position: relative;
    z-index: 2;
    font-size: 0.93vw; /* ~18px */
    font-weight: 500;
    color: {{ section.settings.meta_color }};
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* =========================================
     ARTICLE BODY (Image & Content)
     ========================================= */
  #shopify-section-{{ section.id }} .zbd-article-body {
    width: 75vw;
    max-width: 800px; /* Constrained width for comfortable reading */
    margin: 0 auto;
    padding-top: {{ section.settings.content_padding_top }}vw;
    padding-bottom: {{ section.settings.content_padding_bottom }}vw;
  }

  /* Featured Image */
  #shopify-section-{{ section.id }} .zbd-article__image {
    width: 100%;
    height: auto;
    max-height: 60vh;
    object-fit: cover;
    border-radius: 1.5vw;
    margin-bottom: 4vw;
    box-shadow: 0 1vw 3vw rgba(0,0,0,0.08);
  }

  /* Rich Text Content Formatting */
  #shopify-section-{{ section.id }} .zbd-article__content {
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .zbd-article__content h1,
  #shopify-section-{{ section.id }} .zbd-article__content h2,
  #shopify-section-{{ section.id }} .zbd-article__content h3,
  #shopify-section-{{ section.id }} .zbd-article__content h4,
  #shopify-section-{{ section.id }} .zbd-article__content h5,
  #shopify-section-{{ section.id }} .zbd-article__content h6 {
    color: {{ section.settings.heading_color }};
    font-weight: 700;
    margin-top: 3vw;
    margin-bottom: 1.5vw;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .zbd-article__content h1 { font-size: 2.08vw; } /* ~40px */
  #shopify-section-{{ section.id }} .zbd-article__content h2 { font-size: 1.66vw; } /* ~32px */
  #shopify-section-{{ section.id }} .zbd-article__content h3 { font-size: 1.25vw; } /* ~24px */
  #shopify-section-{{ section.id }} .zbd-article__content h4 { font-size: 1.04vw; } /* ~20px */

  #shopify-section-{{ section.id }} .zbd-article__content p,
  #shopify-section-{{ section.id }} .zbd-article__content li {
    font-size: 0.93vw; /* ~18px */
    line-height: 1.8;
    margin-top: 0;
    margin-bottom: 1.5vw;
  }

  #shopify-section-{{ section.id }} .zbd-article__content ul,
  #shopify-section-{{ section.id }} .zbd-article__content ol {
    margin-bottom: 1.5vw;
    padding-left: 2.5vw;
  }

  #shopify-section-{{ section.id }} .zbd-article__content img {
    max-width: 100%;
    height: auto;
    border-radius: 1vw;
    margin: 2vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-article__content a {
    color: {{ section.settings.link_color }};
    text-decoration: underline;
    transition: opacity 0.2s;
  }

  #shopify-section-{{ section.id }} .zbd-article__content a:hover {
    opacity: 0.7;
  }

  #shopify-section-{{ section.id }} .zbd-article__content blockquote {
    border-left: 0.3vw solid {{ section.settings.link_color }};
    margin: 2vw 0;
    padding: 1vw 0 1vw 2vw;
    font-size: 1.15vw;
    font-style: italic;
    color: {{ section.settings.heading_color }};
    background: rgba(0,0,0,0.02);
    border-radius: 0 0.5vw 0.5vw 0;
  }

  /* Back to Blog Link */
  #shopify-section-{{ section.id }} .zbd-article__back {
    display: inline-flex;
    align-items: center;
    margin-top: 4vw;
    font-size: 0.93vw;
    font-weight: 600;
    color: {{ section.settings.heading_color }};
    text-decoration: none;
    transition: opacity 0.2s;
  }

  #shopify-section-{{ section.id }} .zbd-article__back:hover {
    opacity: 0.7;
  }

  #shopify-section-{{ section.id }} .zbd-article__back svg {
    width: 1.2vw;
    height: 1.2vw;
    margin-right: 0.5vw;
  }

  /* =========================================
     MOBILE RESPONSIVE
     ========================================= */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .zbd-article-hero {
      padding-top: calc({{ section.settings.hero_padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.hero_padding_bottom }}vw * 3);
    }

    #shopify-section-{{ section.id }} .zbd-article-hero__title {
      font-size: 8vw;
      margin-bottom: 3vw;
      max-width: 95vw;
    }

    #shopify-section-{{ section.id }} .zbd-article-hero__meta {
      font-size: 3.5vw;
    }

    #shopify-section-{{ section.id }} .zbd-article-body {
      width: 90vw;
      max-width: 90vw;
      padding-top: calc({{ section.settings.content_padding_top }}vw * 2.5);
      padding-bottom: calc({{ section.settings.content_padding_bottom }}vw * 2.5);
    }

    #shopify-section-{{ section.id }} .zbd-article__image {
      border-radius: 4vw;
      margin-bottom: 8vw;
    }

    /* Mobile Typography */
    #shopify-section-{{ section.id }} .zbd-article__content h1,
    #shopify-section-{{ section.id }} .zbd-article__content h2,
    #shopify-section-{{ section.id }} .zbd-article__content h3,
    #shopify-section-{{ section.id }} .zbd-article__content h4,
    #shopify-section-{{ section.id }} .zbd-article__content h5,
    #shopify-section-{{ section.id }} .zbd-article__content h6 {
      margin-top: 8vw;
      margin-bottom: 4vw;
      font-size: 6vw;
    }

    #shopify-section-{{ section.id }} .zbd-article__content h1 { font-size: 8vw; }
    #shopify-section-{{ section.id }} .zbd-article__content h2 { font-size: 7vw; }
    #shopify-section-{{ section.id }} .zbd-article__content h3 { font-size: 6vw; }
    #shopify-section-{{ section.id }} .zbd-article__content h4 { font-size: 5.5vw; }

    #shopify-section-{{ section.id }} .zbd-article__content p,
    #shopify-section-{{ section.id }} .zbd-article__content li {
      font-size: 4vw;
      margin-bottom: 5vw;
    }

    #shopify-section-{{ section.id }} .zbd-article__content blockquote {
      font-size: 4.5vw;
      border-left-width: 1vw;
      padding: 4vw;
      margin: 6vw 0;
    }

    #shopify-section-{{ section.id }} .zbd-article__back {
      font-size: 4vw;
      margin-top: 10vw;
    }

    #shopify-section-{{ section.id }} .zbd-article__back svg {
      width: 5vw;
      height: 5vw;
      margin-right: 2vw;
    }
  }
</style>

<div class="zbd-article-hero">
  {%- if section.settings.bg_image != blank -%}
    {{ section.settings.bg_image | image_url: width: 2400 | image_tag: class: 'zbd-article-hero__bg', loading: 'eager', alt: article.title }}
  {%- endif -%}

  <h1 class="zbd-article-hero__title">{{ article.title | escape }}</h1>
  
  <div class="zbd-article-hero__meta">
    {%- if section.settings.show_date -%}
      {{ article.published_at | time_tag: format: 'date' }}
    {%- endif -%}
  </div>
</div>

<div class="zbd-article-body">
  
  {%- if article.image != blank -%}
    {{ article.image | image_url: width: 1400 | image_tag: class: 'zbd-article__image', loading: 'eager', alt: article.title }}
  {%- endif -%}

  <div class="zbd-article__content">
    {{ article.content }}
  </div>

  <a href="{{ blog.url }}" class="zbd-article__back">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="19" y1="12" x2="5" y2="12"></line>
      <polyline points="12 19 5 12 12 5"></polyline>
    </svg>
    Back to {{ blog.title }}
  </a>

</div>

{% schema %}
{
  "name": "ZenBud Article Template",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Hero Banner Settings"
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Hero Background Color",
      "default": "#3A78F2"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Hero Background Image"
    },
    {
      "type": "range",
      "id": "bg_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Image Opacity",
      "default": 100
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Author/Date Color",
      "default": "#E5E7EB"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show Publish Date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Show Author",
      "default": true
    },
    {
      "type": "range",
      "id": "hero_padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Hero Padding Top (Desktop)",
      "default": 6.0
    },
    {
      "type": "range",
      "id": "hero_padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Hero Padding Bottom (Desktop)",
      "default": 6.0
    },
    {
      "type": "header",
      "content": "Article Content Settings"
    },
    {
      "type": "color",
      "id": "content_bg_color",
      "label": "Content Area Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Content Headings Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Content Body Text Color",
      "default": "#374151"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#3A78F2"
    },
    {
      "type": "range",
      "id": "content_padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Content Padding Top (Desktop)",
      "default": 6.0
    },
    {
      "type": "range",
      "id": "content_padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Content Padding Bottom (Desktop)",
      "default": 8.0
    }
  ],
  "presets": [
    {
      "name": "ZenBud Article Template",
      "category": "ZenBud Base"
    }
  ]
}
{% endschema %}