{% comment %}
  zenbud-product-glass.liquid
{% endcomment %}

{%- assign product = all_products[section.settings.product] -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100vw;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #111827;
  }

  /* Background Wave Image */
  #shopify-section-{{ section.id }} .zenbud-glass-prod__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Main Glass Card */
  #shopify-section-{{ section.id }} .zenbud-glass-prod__card {
    position: relative;
    z-index: 2;
    width: 85vw;
    max-width: 100%; 
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 4.16vw;
    padding: 4.16vw;
    
    /* Light Glassmorphism for dark text */
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(2.08vw);
    -webkit-backdrop-filter: blur(2.08vw);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 1.56vw;
    box-shadow: 0 1vw 3vw rgba(0, 0, 0, 0.05);
  }

  /* Left: Image Column */
  #shopify-section-{{ section.id }} .zenbud-glass-prod__image-col {
    width: 65%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__image-col img {
    width: 100%;
    height: auto;
    object-fit: contain;
    max-width: 26vw;
    filter: drop-shadow(0 1vw 2vw rgba(0,0,0,0.1));
    transform: scale(1.65);
  }

  /* Right: Info Column */
  #shopify-section-{{ section.id }} .zenbud-glass-prod__info-col {
    width: 35%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__subheading {
    color: {{ section.settings.accent_color }};
    font-size: 0.93vw;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.5vw 0;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__title {
    font-size: 1.56vw;
    font-weight: 600;
    color: #111827;
    margin: 0 0 1vw 0;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__desc {
    font-size: 0.83vw;
    color: #4b5563;
    margin: 0 0 1.5vw 0;
    line-height: 1.5;
  }

  /* Reviews */
  #shopify-section-{{ section.id }} .zenbud-glass-prod__reviews {
    display: flex;
    align-items: center;
    gap: 0.5vw;
    font-size: 0.73vw;
    color: #6b7280;
    margin-bottom: 1.5vw;
    padding-bottom: 1.5vw;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    width: 100%;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__stars {
    color: #FBBF24;
    font-size: 0.93vw;
    letter-spacing: 0.1em;
  }

  /* Price */
  #shopify-section-{{ section.id }} .zenbud-glass-prod__price {
    font-size: 1.56vw;
    font-weight: 700;
    color: #111827;
    margin: 0 0 1.5vw 0;
  }

  /* Benefits List */
  #shopify-section-{{ section.id }} .zenbud-glass-prod__list {
    list-style: none;
    padding: 0;
    margin: 0 0 2vw 0;
    display: flex;
    flex-direction: column;
    gap: 0.5vw;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__list li {
    display: flex;
    align-items: center;
    gap: 0.5vw;
    font-size: 0.83vw;
    color: #374151;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__list-icon {
    width: 1.04vw;
    height: 1.04vw;
    color: {{ section.settings.accent_color }};
  }

  /* Qty */
  #shopify-section-{{ section.id }} .zenbud-glass-prod__qty {
    display: flex;
    align-items: center;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 50px;
    padding: 0 1vw;
    height: 2.8vw;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__qty button {
    background: none;
    border: none;
    color: #111827;
    font-size: 1vw;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__qty input {
    background: transparent;
    border: none;
    color: #111827;
    text-align: center;
    width: 2vw;
    font-weight: 600;
  }

  /* Add to Cart Button */
  #shopify-section-{{ section.id }} .zenbud-glass-prod__atc-btn {
    width: 100%;
    height: 2.8vw;
    background-color: {{ section.settings.accent_color }};
    color: #ffffff;
    border: none;
    border-radius: 50px;
    font-size: 0.83vw;
    font-weight: 700;
    cursor: pointer;
  }

  /* Installments */
  #shopify-section-{{ section.id }} .zenbud-glass-prod__installments {
    font-size: 0.62vw;
    color: #4b5563;
    font-style: italic;
    display: flex;
    align-items: center;
    gap: 0.5vw;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .zenbud-glass-prod__badge {
    background-color: rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.1);
    color: #111827;
    border-radius: 50px;
    padding: 0.2vw 0.5vw;
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .zenbud-glass-prod__card {
      width: 90vw;
      flex-direction: column;
      padding: 6vw;
      border-radius: 6vw;
    }
    #shopify-section-{{ section.id }} .zenbud-glass-prod__title { font-size: 6.5vw; color: #111827; }
    #shopify-section-{{ section.id }} .zenbud-glass-prod__price { font-size: 7vw; color: #111827; }
    #shopify-section-{{ section.id }} .zenbud-glass-prod__desc { font-size: 3.8vw; color: #374151; }
    #shopify-section-{{ section.id }} .zenbud-glass-prod__list li { font-size: 3.8vw; color: #374151; }
    #shopify-section-{{ section.id }} .zenbud-glass-prod__qty button, #shopify-section-{{ section.id }} .zenbud-glass-prod__qty input { color: #111827; }
  }
</style>

<div class="zenbud-glass-prod__card">
  
  <div class="zenbud-glass-prod__image-col">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.title }}
    {%- elsif product != blank and product.featured_image != blank -%}
      {{ product.featured_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: product.title }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="zenbud-glass-prod__info-col">
    {%- if section.settings.subheading != blank -%}
      <h3 class="zenbud-glass-prod__subheading">{{ section.settings.subheading | escape }}</h3>
    {%- endif -%}

    <h2 class="zenbud-glass-prod__title">
      {{ section.settings.title | default: product.title | default: 'ZenBud - Vagus Nerve Stimulator' }}
    </h2>

    {%- if section.settings.description != blank -%}
      <p class="zenbud-glass-prod__desc">{{ section.settings.description | escape }}</p>
    {%- endif -%}

    <div class="zenbud-glass-prod__reviews">
      <span class="zenbud-glass-prod__stars">★★★★★</span>
      <span>{{ section.settings.review_text | escape }}</span>
    </div>

    <div class="zenbud-glass-prod__price">
      {%- if product != blank -%}
        {{ current_variant.price | money }}
      {%- else -%}
        {{ section.settings.fallback_price | escape }}
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <ul class="zenbud-glass-prod__list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'benefit' -%}
            <li {{ block.shopify_attributes }}>
              <svg class="zenbud-glass-prod__list-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              {{ block.settings.text | escape }}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    <div class="zenbud-glass-prod__form-wrapper">
        {% form 'product', product %}
          <input type="hidden" name="id" value="{{ current_variant.id | default: '48167485931839' }}">
          <div class="zenbud-glass-prod__atc-row">
            <div class="zenbud-glass-prod__qty">
              <button type="button" class="qty-minus">−</button>
              <input type="number" name="quantity" value="1" min="1">
              <button type="button" class="qty-plus">+</button>
            </div>
            <button type="submit" class="zenbud-glass-prod__atc-btn">ADD TO CART</button>
          </div>
        {% endform %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const qtyWrapper = document.getElementById('shopify-section-{{ section.id }}');
    if (!qtyWrapper) return;
    
    qtyWrapper.addEventListener('click', (e) => {
      const input = e.target.closest('.zenbud-glass-prod__qty')?.querySelector('input');
      if (!input) return;
      
      if (e.target.classList.contains('qty-minus')) {
        let val = parseInt(input.value);
        if (val > 1) input.value = val - 1;
      } else if (e.target.classList.contains('qty-plus')) {
        let val = parseInt(input.value);
        input.value = val + 1;
      }
    });
  });
</script>

{% schema %}
{
  "name": "ZenBud Glass Product",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#F9FAFB" },
    { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#3A78F2" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 15, "step": 0.5, "unit": "vw", "label": "Padding Top", "default": 8.0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 15, "step": 0.5, "unit": "vw", "label": "Padding Bottom", "default": 8.0 },
    { "type": "product", "id": "product", "label": "Select Product" },
    { "type": "image_picker", "id": "image", "label": "Custom Product Image" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "GET STARTED" },
    { "type": "text", "id": "title", "label": "Title" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Gentle ultrasound activates your body's natural calm response." },
    { "type": "text", "id": "review_text", "label": "Review Text", "default": "1.2K Reviews • 4.5 Average rating" },
    { "type": "text", "id": "fallback_price", "label": "Fallback Price", "default": "$459.00" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Checkmark",
      "settings": [ { "type": "text", "id": "text", "label": "Benefit Text" } ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud Glass Product",
      "blocks": [
        { "type": "benefit", "settings": { "text": "90-day money-back guarantee" } },
        { "type": "benefit", "settings": { "text": "1-year manufacturer warranty" } }
      ]
    }
  ]
}
{% endschema %}