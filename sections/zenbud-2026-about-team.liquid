{% comment %}
  zenbud-about-team.liquid
{% endcomment %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100vw;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    overflow: hidden;
    display: block;
  }

  /* Background Image Layer */
  #shopify-section-{{ section.id }} .zbd-team__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    pointer-events: none;
    opacity: {{ section.settings.bg_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .zbd-team__container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  /* Section Header */
  #shopify-section-{{ section.id }} .zbd-team__header-container {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .zbd-team__header-inner {
    width: 100%;
    max-width: 85vw;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .zbd-team__section-heading {
    font-size: 2.08vw; /* ~40px */
    font-weight: 700;
    font-style: italic;
    color: {{ section.settings.heading_color }};
    /* Aligns perfectly with the left edge of the glass box (45% - 10% overlap = 35%) */
    margin: 0 0 2vw 35%;
    line-height: 1.2;
  }

  /* Main Interactive Area */
  #shopify-section-{{ section.id }} .zbd-team__main-content {
    display: flex;
    flex-direction: row;
    align-items: center;
    width: 100%;
    max-width: 85vw;
    margin: 0 auto;
    position: relative;
  }

  /* Left: Static Images Column (SITS ON TOP) */
  #shopify-section-{{ section.id }} .zbd-team__images-col {
    width: 45%;
    position: relative;
    z-index: 3; /* Higher z-index forces it above the slider */
    display: grid; /* Grid stacking allows smooth crossfading without absolute positioning height issues */
  }

  #shopify-section-{{ section.id }} .zbd-team__image-item {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }

  #shopify-section-{{ section.id }} .zbd-team__image-item.is-active {
    opacity: 1;
    visibility: visible;
  }

  #shopify-section-{{ section.id }} .zbd-team__image-item img {
    width: 100%;
    height: 35vw;
    object-fit: cover;
    display: block;
    border-radius: 1.5vw;
    box-shadow: 0 1vw 3vw rgba(0,0,0,0.4);
  }

  /* Right: Slider Column (SITS BEHIND) */
  #shopify-section-{{ section.id }} .zbd-team__slider-col {
    width: 65%;
    position: relative;
    z-index: 2; /* Lower z-index places it behind the image */
    margin-left: -10%; /* Pulls the slider container under the image */
  }

  /* Swiper Slide content */
  #shopify-section-{{ section.id }} .swiper-slide {
    height: auto;
    padding-top: 2vw;
    padding-bottom: 2vw;
  }

  /* Glass Card inside the slide */
  #shopify-section-{{ section.id }} .zbd-team__card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(24px) brightness(1.2);
    -webkit-backdrop-filter: blur(24px) brightness(1.2);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 1.5vw;
    padding: 4vw 4vw 4vw 8vw; /* Extra left padding so text clears the image overlap */
    color: #ffffff;
    box-shadow: 0 2vw 4vw rgba(0, 0, 0, 0.2);
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .zbd-team__name {
    font-size: 2.08vw; /* ~40px */
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 0 0.2vw 0;
    line-height: 1.1;
  }

  #shopify-section-{{ section.id }} .zbd-team__title {
    font-size: 1.04vw; /* ~20px */
    font-weight: 400;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
    margin: 0 0 1.5vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-team__bio {
    font-size: 0.93vw; /* ~18px */
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  /* Navigation Arrows */
  #shopify-section-{{ section.id }} .zbd-team__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 3vw;
    height: 3vw;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    color: #ffffff;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .zbd-team__nav:hover {
    transform: translateY(-50%) scale(1.1);
  }

  #shopify-section-{{ section.id }} .zbd-team__nav.swiper-button-disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: translateY(-50%) scale(1);
  }

  #shopify-section-{{ section.id }} .zbd-team__nav svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    stroke-width: 2;
  }

  /* Position arrows outside the layout on desktop */
  #shopify-section-{{ section.id }} .zbd-team__prev { left: -4vw; }
  #shopify-section-{{ section.id }} .zbd-team__next { right: -4vw; }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    
    #shopify-section-{{ section.id }} .zbd-team__section-heading {
      font-size: 7vw;
      margin: 0 0 6vw 0;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .zbd-team__main-content {
      flex-direction: column;
      max-width: 90vw;
    }

    /* Stack Image on top */
    #shopify-section-{{ section.id }} .zbd-team__images-col {
      width: 90%;
      margin: 0 auto;
    }

    #shopify-section-{{ section.id }} .zbd-team__image-item img {
      height: 80vw;
      border-radius: 4vw;
    }

    /* Slide Card below */
    #shopify-section-{{ section.id }} .zbd-team__slider-col {
      width: 100%;
      margin-left: 0;
      margin-top: -15%; /* Pulls the glass card up behind the bottom of the image */
    }

    #shopify-section-{{ section.id }} .zbd-team__card {
      padding: 20vw 6vw 8vw 6vw; /* Massive top padding to clear the image */
      border-radius: 6vw;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .zbd-team__name { font-size: 8vw; margin-bottom: 1vw; }
    #shopify-section-{{ section.id }} .zbd-team__title { font-size: 4vw; margin-bottom: 4vw; }
    #shopify-section-{{ section.id }} .zbd-team__bio { font-size: 4vw; }
    
    /* Move arrows inside on mobile */
    #shopify-section-{{ section.id }} .zbd-team__nav {
      width: 8vw;
      height: 8vw;
      top: 60%; /* Align with the text card */
    }
    #shopify-section-{{ section.id }} .zbd-team__prev { left: 0vw; }
    #shopify-section-{{ section.id }} .zbd-team__next { right: 0vw; }
  }
</style>

{%- if section.settings.bg_image != blank -%}
  {{ section.settings.bg_image | image_url: width: 2400 | image_tag: class: 'zbd-team__bg', loading: 'lazy', alt: 'Background' }}
{%- endif -%}

<div class="zbd-team__container">
  
  <div class="zbd-team__header-container">
    <div class="zbd-team__header-inner">
      {%- if section.settings.heading != blank -%}
        <h2 class="zbd-team__section-heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>
  </div>

  <div class="zbd-team__main-content">
    
    <div class="zbd-team__images-col">
      {%- for block in section.blocks -%}
        <div class="zbd-team__image-item {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.name }}
          {%- elsif block.settings.image_url != blank -%}
            <img src="{{ block.settings.image_url }}" alt="{{ block.settings.name }}" loading="lazy">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="zbd-team__slider-col">
      <div class="swiper zbd-swiper-{{ section.id }}">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <div class="zbd-team__card">
                <h3 class="zbd-team__name">{{ block.settings.name | escape }}</h3>
                <h4 class="zbd-team__title">{{ block.settings.title | escape }}</h4>
                <div class="zbd-team__bio">
                  {{ block.settings.bio }}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="zbd-team__prev zbd-team__nav">
      <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </div>
    <div class="zbd-team__next zbd-team__nav">
      <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </div>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.zbd-swiper-{{ section.id }}', {
      loop: false,
      speed: 600, // Smooth horizontal slide
      spaceBetween: 30,
      navigation: {
        nextEl: '#shopify-section-{{ section.id }} .zbd-team__next',
        prevEl: '#shopify-section-{{ section.id }} .zbd-team__prev',
      },
      on: {
        slideChange: function () {
          // When the slide changes, update the image crossfade
          const activeIndex = this.activeIndex;
          const images = document.querySelectorAll('#shopify-section-{{ section.id }} .zbd-team__image-item');
          
          images.forEach((img, index) => {
            if(index === activeIndex) {
              img.classList.add('is-active');
            } else {
              img.classList.remove('is-active');
            }
          });
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "ZenBud About Team",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
