{% comment %}
  zenbud-community-grid.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    width: 100vw;
  }

  #shopify-section-{{ section.id }} .zbd-grid__container {
    width: 90vw;
    max-width: 1440px;
    margin: 0 auto;
  }

  /* CSS Grid Layout */
  #shopify-section-{{ section.id }} .zbd-grid__wrapper {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5vw;
    align-items: stretch;
  }

  /* Grid Sizing Classes */
  #shopify-section-{{ section.id }} .zbd-span-1 { grid-column: span 1; }
  #shopify-section-{{ section.id }} .zbd-span-2 { grid-column: span 2; }

  /* Standard Card Styling */
  #shopify-section-{{ section.id }} .zbd-card {
    border-radius: 1.5vw;
    padding: 3vw;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border: 1px solid rgba(0,0,0,0.05);
    height: 100%;
    box-sizing: border-box;
  }

  /* Split Card Styling (Text + Video) */
  #shopify-section-{{ section.id }} .zbd-split-card {
    display: flex;
    flex-direction: row;
    border-radius: 1.5vw;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.05);
    height: 100%;
  }

  #shopify-section-{{ section.id }} .zbd-split-text {
    flex: 1;
    padding: 3vw;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .zbd-split-video {
    flex: 1;
    position: relative;
  }

  /* Colors */
  #shopify-section-{{ section.id }} .zbd-bg-white {
    background-color: {{ section.settings.card_bg_white }};
    color: #111827;
  }

  #shopify-section-{{ section.id }} .zbd-bg-blue {
    background-color: {{ section.settings.card_bg_blue }};
    color: #FFFFFF;
  }

  /* Typography */
  #shopify-section-{{ section.id }} .zbd-card h3, 
  #shopify-section-{{ section.id }} .zbd-split-text h3 {
    font-size: 1.87vw; /* ~36px */
    font-weight: 700;
    margin: 0 0 1vw 0;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .zbd-card p, 
  #shopify-section-{{ section.id }} .zbd-split-text p {
    font-size: 1.04vw; /* ~20px */
    line-height: 1.5;
    margin: 0 0 1vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-card p:last-child, 
  #shopify-section-{{ section.id }} .zbd-split-text p:last-child {
    margin-bottom: 0;
  }

  /* Video Container Styling */
  #shopify-section-{{ section.id }} .zbd-video-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 1.5vw;
    background: #000;
  }

  #shopify-section-{{ section.id }} .zbd-split-card .zbd-video-container {
    border-radius: 0; /* Inherits rounded corners from the parent split card */
  }

  #shopify-section-{{ section.id }} .hover-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .video-thumbnail {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 5;
    transition: opacity 0.3s ease;
  }

  #shopify-section-{{ section.id }} .play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 4vw;
    height: 4vw;
    cursor: pointer;
    z-index: 10;
    transition: opacity 0.3s ease;
  }

  /* Hide thumbnail and play button when playing */
  #shopify-section-{{ section.id }} .zbd-video-container.playing .play-button {
    display: none !important;
  }
  
  #shopify-section-{{ section.id }} .zbd-video-container.playing .video-thumbnail {
    opacity: 0;
    pointer-events: none;
  }

  /* Load More Button */
  #shopify-section-{{ section.id }} .zbd-load-more-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 4vw;
  }

  #shopify-section-{{ section.id }} .zbd-load-more {
    font-size: 1.04vw; /* ~20px */
    font-weight: 600;
    color: #111827;
    text-decoration: underline;
    transition: opacity 0.3s ease;
  }

  #shopify-section-{{ section.id }} .zbd-load-more:hover {
    opacity: 0.7;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    
    #shopify-section-{{ section.id }} .zbd-grid__container {
      width: 90vw;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .zbd-grid__wrapper {
      grid-template-columns: 1fr;
      gap: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-span-1,
    #shopify-section-{{ section.id }} .zbd-span-2 {
      grid-column: span 1;
    }

    #shopify-section-{{ section.id }} .zbd-split-card {
      flex-direction: column-reverse; /* Puts video on top, text on bottom */
      border-radius: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-card,
    #shopify-section-{{ section.id }} .zbd-video-container {
      border-radius: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-split-video,
    #shopify-section-{{ section.id }} .zbd-video-container {
      height: 60vw; /* Fixed height for videos on mobile */
    }

    #shopify-section-{{ section.id }} .zbd-card,
    #shopify-section-{{ section.id }} .zbd-split-text {
      padding: 6vw;
    }

    #shopify-section-{{ section.id }} .zbd-card h3, 
    #shopify-section-{{ section.id }} .zbd-split-text h3 {
      font-size: 6vw;
      margin-bottom: 3vw;
    }

    #shopify-section-{{ section.id }} .zbd-card p, 
    #shopify-section-{{ section.id }} .zbd-split-text p {
      font-size: 4vw;
      margin-bottom: 3vw;
    }

    #shopify-section-{{ section.id }} .play-button {
      width: 15vw;
      height: 15vw;
    }

    #shopify-section-{{ section.id }} .zbd-load-more {
      font-size: 4.5vw;
      margin-top: 8vw;
    }
  }
</style>

<div class="zbd-grid__container">
  
  <div class="zbd-grid__wrapper">
    {%- for block in section.blocks -%}
      
      {%- case block.type -%}
        
        {%- when 'text_card' -%}
          <div class="zbd-card {% if block.settings.width == '2' %}zbd-span-2{% else %}zbd-span-1{% endif %} {% if block.settings.color_scheme == 'blue' %}zbd-bg-blue{% else %}zbd-bg-white{% endif %}" {{ block.shopify_attributes }}>
            <h3>{{ block.settings.title | escape }}</h3>
            <p>{{ block.settings.text }}</p>
            <p><strong>{{ block.settings.author | escape }}</strong></p>
          </div>

        {%- when 'video_card' -%}
          <div class="zbd-span-1" {{ block.shopify_attributes }}>
            <div class="zbd-video-container">
              <video class="hover-video" src="{{ block.settings.video_url }}" loop muted playsinline width="100%"></video>
              {%- if block.settings.thumbnail_url != blank -%}
                <img src="{{ block.settings.thumbnail_url }}" alt="Thumbnail" class="video-thumbnail" loading="lazy">
              {%- endif -%}
              
              {%- if section.settings.play_button != blank -%}
                {{ section.settings.play_button | image_url: width: 200 | image_tag: class: 'play-button', loading: 'lazy', alt: 'Play' }}
              {%- else -%}
                <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/play-button.png?v=1762810277" alt="Play Button" class="play-button" loading="lazy">
              {%- endif -%}
            </div>
          </div>

        {%- when 'split_card' -%}
          <div class="zbd-split-card zbd-span-2 zbd-bg-blue" {{ block.shopify_attributes }}>
            <div class="zbd-split-text">
              <h3>{{ block.settings.title | escape }}</h3>
              <p>{{ block.settings.text }}</p>
              <p><strong>{{ block.settings.author | escape }}</strong></p>
            </div>
            <div class="zbd-split-video">
              <div class="zbd-video-container">
                <video class="hover-video" src="{{ block.settings.video_url }}" loop muted playsinline width="100%"></video>
                {%- if block.settings.thumbnail_url != blank -%}
                  <img src="{{ block.settings.thumbnail_url }}" alt="Thumbnail" class="video-thumbnail" loading="lazy">
                {%- endif -%}
                
                {%- if section.settings.play_button != blank -%}
                  {{ section.settings.play_button | image_url: width: 200 | image_tag: class: 'play-button', loading: 'lazy', alt: 'Play' }}
                {%- else -%}
                  <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/play-button.png?v=1762810277" alt="Play Button" class="play-button" loading="lazy">
                {%- endif -%}
              </div>
            </div>
          </div>

      {%- endcase -%}

    {%- endfor -%}
  </div>

  {%- if section.settings.show_load_more -%}
    <div class="zbd-load-more-wrapper">
      <a href="{{ section.settings.load_more_link | default: '#' }}" class="zbd-load-more">{{ section.settings.load_more_text }}</a>
    </div>
  {%- endif -%}

</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const isMobile = window.matchMedia("(max-width: 768px)").matches;
    const videoContainers = document.querySelectorAll('#shopify-section-{{ section.id }} .zbd-video-container');

    videoContainers.forEach(container => {
      const video = container.querySelector('.hover-video');
      const playButton = container.querySelector('.play-button');
      const thumbnail = container.querySelector('.video-thumbnail');
      
      let userPaused = false; 

      video.pause();
      video.volume = 0; 
      playButton.style.display = 'block'; 

      video.addEventListener('pause', () => {
        if (!isMobile) {
          if (container.matches(':hover')) {
            userPaused = true;
            container.classList.remove('playing');
          }
        }
      });
      
      video.addEventListener('play', () => {
        if (!isMobile) {
          userPaused = false;
          container.classList.add('playing');
        }
      });

      if (isMobile) {
        container.classList.add('mobile-paused');
        video.removeAttribute('controls');

        const startElements = [playButton, thumbnail];
        startElements.forEach(el => {
          if(!el) return;
          el.addEventListener('click', () => {
            if (video.paused) {
              const playPromise = video.play();
              if (playPromise !== undefined) {
                playPromise.then(() => {
                  video.muted = false;
                  video.volume = 1; 
                  video.setAttribute('controls', 'true'); 
                  playButton.style.display = 'none';
                  if(thumbnail) thumbnail.style.display = 'none'; 
                  container.classList.remove('mobile-paused');
                  
                  video.onended = () => {
                    video.removeAttribute('controls');
                    video.currentTime = 0;
                    playButton.style.display = 'block'; 
                    if(thumbnail) thumbnail.style.display = 'block';
                    container.classList.add('mobile-paused');
                  };
                }).catch(error => {
                  console.error("Video playback prevented on click:", error);
                });
              }
            }
          });
        });

      } else {
        container.addEventListener('mouseover', () => {
          if (userPaused) return; 
          const playPromise = video.play();
          if (playPromise !== undefined) {
            playPromise.then(() => {
              video.muted = false;
              video.volume = 1;
              container.classList.add('playing');
            }).catch(error => {
              console.error("Desktop playback prevented:", error);
            });
          }
        });

        container.addEventListener('mouseout', () => {
          video.pause();
          video.muted = true;
          container.classList.remove('playing');
          userPaused = false; 
        });
      }
    });
  });
</script>

