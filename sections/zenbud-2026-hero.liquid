{% comment %}
  zenbud-hero.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100%;
    background-color: {{ section.settings.bg_color }};
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2400 }}');
    {% else %}
      background-image: url('{{ "zenbud-2026-hero.webp" | asset_url }}');
    {% endif %}
    background-size: cover;
    background-position: center right;
    background-repeat: no-repeat;
    min-height: 55vw; /* 900px / 19.2 */
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Base CSS for all background videos */
  #shopify-section-{{ section.id }} .zenbud-hero__video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none; /* Prevents users from clicking/pausing the video */
  }

  /* Hide the mobile video on desktop */
  #shopify-section-{{ section.id }} .zenbud-hero__video--mobile {
    display: none;
  }

  #shopify-section-{{ section.id }} .zenbud-hero__container {
    position: relative;
    z-index: 1; /* Ensures the container sits on top of the background video */
    width: 85vw; /* 90% container width as requested */
    margin: 0 auto;
    padding-top: 3.12vw; /* 60px */
    padding-bottom: 3.12vw; /* 60px */
  }

  #shopify-section-{{ section.id }} .zenbud-hero__card {
    background-color: {{ section.settings.card_bg }};
    border-radius: 1.66vw; /* 32px */
    padding: 2.5vw; /* 48px */
    max-width: 40vw; /* 540px */
    display: flex;
    flex-direction: column;
    gap: 1.25vw; /* 24px */
    box-shadow: 0 1.04vw 2.08vw rgba(0, 0, 0, 0.4); /* 0 20px 40px */
    position: relative;
    z-index: 2;
    background-color: rgba(255, 255, 255, 0.15);
    -webkit-backdrop-filter: blur(5px);
    backdrop-filter: blur(30px);
  }

  #shopify-section-{{ section.id }} .zenbud-hero__heading {
    font-size: 1.87vw; /* 36px */
    line-height: 1.25;
    font-weight: 400;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.01em;
  }

  #shopify-section-{{ section.id }} .zenbud-hero__heading-highlight {
    color: {{ section.settings.highlight_color }};
  }

  #shopify-section-{{ section.id }} .zenbud-hero__text {
    font-size: 0.83vw; /* 16px */
    line-height: 1.6;
    color: #c4c4c4;
    margin: 0;
    max-width: 95%;
  }

  #shopify-section-{{ section.id }} .zenbud-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.highlight_color }};
    color: #ffffff;
    border-radius: 2.6vw; /* 50px */
    padding: 0.93vw 2.08vw; /* 18px 40px */
    font-size: 0.73vw; /* 14px */
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: none;
    transition: background-color var(--animation-speed) var(--animation-easing), opacity 0.3s ease;
    margin-top: 0.41vw; /* 8px */
    width: fit-content;
  }

  #shopify-section-{{ section.id }} .zenbud-hero__button:hover {
    opacity: 0.9;
    background-color: {{ section.settings.highlight_color | color_lighten: 10 }};
  }

  #shopify-section-{{ section.id }} .zenbud-hero__reviews {
    display: flex;
    align-items: center;
    gap: 0.62vw; /* 12px */
    margin-top: 0.2vw; /* 4px */
  }

  #shopify-section-{{ section.id }} .zenbud-hero__stars {
    height: 0.73vw; /* 14px */
    width: auto;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .zenbud-hero__reviews-text {
    font-size: 0.67vw; /* 13px */
    color: #a0a0a0;
  }

  #shopify-section-{{ section.id }} .zenbud-hero__badges-wrapper {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.25vw; /* 24px */
    margin-top: 0.41vw; /* 8px */
  }

  #shopify-section-{{ section.id }} .zenbud-hero__badge {
    display: flex;
    align-items: center;
    gap: 0.41vw; /* 8px */
  }

  #shopify-section-{{ section.id }} .zenbud-hero__badge img {
    width: 1.04vw; /* 20px */
    height: 1.04vw; /* 20px */
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .zenbud-hero__badge span {
    font-size: 0.67vw; /* 13px */
    color: #a0a0a0;
  }

  /* Responsive styling for readability on mobile devices */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      background-position: center 20%;
      align-items: flex-start;
      min-height: 210svw;
      padding-bottom: 0;
      padding-top: 30vw;
      background: #000;
    }
    
    /* Logic to swap videos if a mobile video is uploaded */
    {% if section.settings.bg_video_mobile != blank %}
      #shopify-section-{{ section.id }} .zenbud-hero__video--desktop {
        display: none;
      }
      #shopify-section-{{ section.id }} .zenbud-hero__video--mobile {
        display: block;
        object-fit: cover;
        object-position: 0 20vw;
      }
    {% endif %}

    #shopify-section-{{ section.id }} .zenbud-hero__container {
      width: 90vw;
      padding-top: 5vw;
      padding-bottom: 5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__card {
      padding: 6vw;
      border-radius: 4vw;
      max-width: 100%;
      gap: 3vw;
      margin: 0 auto;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__heading {
      font-size: 7vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__text {
      font-size: 3.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__button {
      width: 100%;
      border-radius: 8vw;
      padding: 3vw 6vw;
      font-size: 3.2vw;
      margin-top: 2vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__reviews {
      gap: 2vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__stars {
        width: 15vw;
        height: auto;
    }
    #shopify-section-{{ section.id }} .zenbud-stars {
      height: 3vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__reviews-text {
      font-size: 3vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__badges-wrapper {
      flex-direction: column;
      align-items: flex-start;
      gap: 2vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__badge {
      gap: 2vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__badge img {
      width: 4vw;
      height: 4vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__badge span {
      font-size: 3vw;
    }
  }

  @media screen and (min-width: 767px) and (max-width: 1023px) {
    #shopify-section-{{ section.id }} {
        min-height: 75vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__container {
      max-width: 90vw;
      width: 90vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__text {
      font-size: 1.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__reviews-text {
      font-size: 1.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__button {
      padding: 1vw 3vw;
      font-size: 1.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__badge span {
      font-size: 1.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-hero__card {
      max-width: 50vw;
    }
  }
</style>

{%- if section.settings.bg_video != blank -%}
  {{ section.settings.bg_video | video_tag: autoplay: true, loop: false, muted: true, playsinline: true, controls: false, class: 'zenbud-hero__video zenbud-hero__video--desktop' }}
{%- endif -%}

{%- if section.settings.bg_video_mobile != blank -%}
  {{ section.settings.bg_video_mobile | video_tag: autoplay: true, loop: false, muted: true, playsinline: true, controls: false, class: 'zenbud-hero__video zenbud-hero__video--mobile' }}
{%- endif -%}

<div class="zenbud-hero__container">
  <div class="zenbud-hero__card">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        
        {%- when 'heading' -%}
          <h1 class="zenbud-hero__heading h1" {{ block.shopify_attributes }}>
            {{ block.settings.heading }}
            {% if block.settings.highlight_text != blank %}
              <span class="zenbud-hero__heading-highlight">{{ block.settings.highlight_text | escape }}</span>
            {% endif %}
          </h1>
          
        {%- when 'text' -%}
          <p class="zenbud-hero__text paragraph" {{ block.shopify_attributes }}>
            {{ block.settings.text | escape }}
          </p>
          
        {%- when 'button' -%}
          <a href="{{ block.settings.link | default: '#' }}" class="zenbud-hero__button" {{ block.shopify_attributes }}>
            {{ block.settings.label | escape }}
          </a>
          
        {%- when 'reviews' -%}
          <div class="zenbud-hero__reviews" {{ block.shopify_attributes }}>
            {%- if block.settings.stars_image != blank -%}
              {{ block.settings.stars_image | image_url: height: 28 | image_tag: class: 'zenbud-hero__stars', loading: 'lazy' }}
            {%- else -%}
              <img src="{{ 'zenbud-2026-herostars.png' | asset_url }}" alt="5 Stars Rating" class="zenbud-hero__stars" loading="lazy">
            {%- endif -%}
            <span class="zenbud-hero__reviews-text">{{ block.settings.text | escape }}</span>
          </div>
          
        {%- when 'trust_badges' -%}
          <div class="zenbud-hero__badges-wrapper" {{ block.shopify_attributes }}>
            <div class="zenbud-hero__badge">
              {%- if block.settings.icon_1 != blank -%}
                {{ block.settings.icon_1 | image_url: width: 40 | image_tag: loading: 'lazy' }}
              {%- else -%}
                <img src="{{ 'zenbud-2026-heroshock.png' | asset_url }}" alt="No electrical shock" loading="lazy">
              {%- endif -%}
              <span>{{ block.settings.text_1 | escape }}</span>
            </div>
            <div class="zenbud-hero__badge">
              {%- if block.settings.icon_2 != blank -%}
                {{ block.settings.icon_2 | image_url: width: 40 | image_tag: loading: 'lazy' }}
              {%- else -%}
                <img src="{{ 'zenbud-2026-hero90day.png' | asset_url }}" alt="90-Day guarantee" loading="lazy">
              {%- endif -%}
              <span>{{ block.settings.text_2 | escape }}</span>
            </div>
          </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

<script>
  function initZenbudHeroVideo{{ section.id | remove: '-' }}() {
    const container = document.getElementById('shopify-section-{{ section.id }}');
    if (!container) return;

    const videos = container.querySelectorAll('.zenbud-hero__video');
    
    videos.forEach(video => {
      // Set target running speed to 0.75x
      video.playbackRate = 0.85;

      // Re-apply playback rate if browsers clear it on play state changes
      video.addEventListener('play', () => {
        video.playbackRate = 0.85;
      });

      // Explicitly catch termination to stop cleanly on the last frame
      video.addEventListener('ended', () => {
        video.pause();
        video.currentTime = video.duration - 0.01; // Tiny fallback shift to keep frame stable
      });
    });
  }

  // Handle standard initialization and theme customization updates
  document.addEventListener('DOMContentLoaded', initZenbudHeroVideo{{ section.id | remove: '-' }});
  if (window.Shopify && window.Shopify.designMode) {
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initZenbudHeroVideo{{ section.id | remove: '-' }}();
      }
    });
  }
</script>

{% schema %}
{
  "name": "ZenBud Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "video",
      "id": "bg_video",
      "label": "Desktop Background Video",
      "info": "Upload an MP4 video to use as the background. Overlays on top of the Background Image."
    },
    {
      "type": "video",
      "id": "bg_video_mobile",
      "label": "Mobile Background Video (Optional)",
      "info": "Upload a vertical MP4 video for mobile. If left blank, the Desktop video will be used."
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (Fallback)",
      "info": "Leave blank to use the default asset. Will display if the video fails to load or before it starts playing."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#050505"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background Color",
      "default": "#272727"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight & Button Color",
      "default": "#2E62DB"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Regular Text",
          "default": "Your Nervous System Has an Off Switch."
