{% comment %}
  zenbud-about-moment.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    width: 100vw;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zbd-about-moment__container {
    width: 90vw;
    max-width: 65vw; /* ~1200px - Keeps the text from getting too wide to read comfortably */
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zbd-about-moment__heading {
    font-size: 2.08vw; /* ~40px */
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1.5vw 0;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .zbd-about-moment__text {
    font-size: 1.04vw; /* ~20px */
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    
    #shopify-section-{{ section.id }} .zbd-about-moment__container {
      width: 90vw;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .zbd-about-moment__heading {
      font-size: 7vw;
      margin-bottom: 5vw;
    }

    #shopify-section-{{ section.id }} .zbd-about-moment__text {
      font-size: 4.5vw;
    }
  }
</style>

<div class="zbd-about-moment__container">
  
  {%- if section.settings.heading != blank -%}
    <h2 class="zbd-about-moment__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  {%- if section.settings.text != blank -%}
    <p class="zbd-about-moment__text">{{ section.settings.text | escape }}</p>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "ZenBud About Moment",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#F3F4F6"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 8.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 8.0
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Moment That Sparked It"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text",
      "default": "Stress and distraction were becoming the default. Our founders—drawing from neuroscience, product design, and human performance—saw an opportunity to translate emerging research into something accessible: short, guided sessions you can use anywhere, any time, to nudge your nervous system toward the state you need most."
    }
  ],
  "presets": [
    {
      "name": "ZenBud About Moment",
      "category": "ZenBud About"
    }
  ]
}
{% endschema %}