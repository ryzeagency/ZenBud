{% comment %}
  zenbud-hsa-steps.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    width: 100vw;
  }

  #shopify-section-{{ section.id }} .zbd-hsa-steps__container {
    width: 90vw;
    max-width: 80vw; /* ~1440px */
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Section Heading */
  #shopify-section-{{ section.id }} .zbd-hsa-steps__heading {
    font-size: 2.08vw; /* ~40px */
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin: 0 0 4vw 0;
    text-align: center;
  }

  /* Grid Layout */
  #shopify-section-{{ section.id }} .zbd-hsa-steps__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3vw;
    width: 100%;
  }

  /* Individual Step Card */
  #shopify-section-{{ section.id }} .zbd-hsa-steps__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .zbd-hsa-steps__image-wrap {
    width: 100%;
    margin-bottom: 2vw;
  }

  #shopify-section-{{ section.id }} .zbd-hsa-steps__image-wrap img {
    width: 100%;
    height: auto;
    object-fit: contain;
    /* We don't add border-radius here assuming your combined image already has it, 
       but if it's a square image, you can uncomment the line below */
    /* border-radius: 1vw; */
  }

  #shopify-section-{{ section.id }} .zbd-hsa-steps__title {
    font-size: 1.25vw; /* ~24px */
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 0 0.8vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-hsa-steps__text {
    font-size: 0.93vw; /* ~18px */
    line-height: 1.5;
    color: {{ section.settings.text_color }};
    opacity: 0.9;
    margin: 0;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    
    #shopify-section-{{ section.id }} .zbd-hsa-steps__container {
      width: 90vw;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .zbd-hsa-steps__heading {
      font-size: 7vw;
      margin-bottom: 8vw;
    }

    #shopify-section-{{ section.id }} .zbd-hsa-steps__grid {
      grid-template-columns: 1fr;
      gap: 10vw; /* Larger gap on mobile when stacked */
    }

    #shopify-section-{{ section.id }} .zbd-hsa-steps__image-wrap {
      margin-bottom: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-hsa-steps__title {
      font-size: 5vw;
      margin-bottom: 2vw;
    }

    #shopify-section-{{ section.id }} .zbd-hsa-steps__text {
      font-size: 4vw;
    }
  }
</style>

<div class="zbd-hsa-steps__container">
  
  {%- if section.settings.heading != blank -%}
    <h2 class="zbd-hsa-steps__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="zbd-hsa-steps__grid">
      {%- for block in section.blocks -%}
        <div class="zbd-hsa-steps__item" {{ block.shopify_attributes }}>
          
          <div class="zbd-hsa-steps__image-wrap">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          {%- if block.settings.title != blank -%}
            <h3 class="zbd-hsa-steps__title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <p class="zbd-hsa-steps__text">{{ block.settings.text | escape }}</p>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "ZenBud HSA Steps",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 8.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 8.0
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Checking Out with Truemed is Easy!"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Combined Image & Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Step Description",
          "default": "Description of the step goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud HSA Steps",
      "category": "ZenBud HSA Page",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Checkout",
            "text": "Find the Truemed logo during checkout. Exit the “Shop Pay” pop-up if prompted."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Complete Health Assessment",
            "text": "Take a quick, private health survey. A licensed provider will review your answers to determine eligibility."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Make your purchase",
            "text": "Pay with your HSA/FSA card or a credit card. If you use a regular credit card, follow the guide included with your LMN to submit your purchase for reimbursement."
          }
        }
      ]
    }
  ]
}
{% endschema %}