{% comment %}
  zenbud-affiliate-hero.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100vw;
    background-color: {{ section.settings.bg_color }};
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__container {
    position: relative;
    z-index: 2;
    width: 85vw; /* ~1440px max */
    max-width: 85vw;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 4vw;
  }

  /* Left: Card Column */
  #shopify-section-{{ section.id }} .zbd-aff-hero__card-col {
    flex: 1;
    max-width: 40vw; /* Keeps the card from getting too wide */
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__card {
    background-color: {{ section.settings.card_bg }};
    border-radius: 1.66vw; /* ~32px */
    padding: 3vw; /* ~48px */
    display: flex;
    flex-direction: column;
    gap: 1.25vw; /* ~24px */
    box-shadow: 0 1.04vw 2.08vw rgba(0, 0, 0, 0.4);
    position: relative;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__heading {
    font-size: 1.87vw; /* ~36px */
    line-height: 1.25;
    font-weight: 300;
    color: {{ section.settings.heading_color }};
    margin: 0;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__heading-highlight {
    color: {{ section.settings.highlight_color }};
    font-weight: 600;
    font-style: italic;
    display: block;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__text-block {
    display: flex;
    flex-direction: column;
    gap: 0.8vw;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__text {
    font-size: 0.93vw; /* ~18px */
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__text p {
    margin: 0 0 1vw 0;
  }
  
  #shopify-section-{{ section.id }} .zbd-aff-hero__text p:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__author {
    font-size: 0.73vw; /* ~14px */
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: {{ section.settings.highlight_color }};
    margin: 0;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.highlight_color }};
    color: #ffffff;
    border-radius: 2.6vw; /* 50px */
    padding: 0.93vw 2.5vw; /* 18px 40px */
    font-size: 0.83vw; /* 16px */
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: none;
    transition: opacity 0.3s ease, transform 0.2s ease;
    margin-top: 0.5vw; 
    width: fit-content;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__button:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__reviews {
    display: flex;
    align-items: center;
    gap: 0.62vw; /* 12px */
    margin-top: 0.5vw; 
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__stars {
    height: 0.83vw; /* 16px */
    width: auto;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__reviews-text {
    font-size: 0.73vw; /* 14px */
    color: {{ section.settings.text_color }};
    opacity: 0.8;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__badges-wrapper {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.25vw; /* 24px */
    margin-top: 0.5vw;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__badge {
    display: flex;
    align-items: center;
    gap: 0.41vw; /* 8px */
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__badge img {
    width: 1.04vw; /* 20px */
    height: 1.04vw; /* 20px */
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__badge span {
    font-size: 0.73vw; /* 14px */
    color: {{ section.settings.text_color }};
    opacity: 0.8;
  }

  /* Right: Image Column */
  #shopify-section-{{ section.id }} .zbd-aff-hero__image-col {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
  }

  #shopify-section-{{ section.id }} .zbd-aff-hero__image {
    width: 100%;
    max-height: 100%;
    object-fit: contain;
    object-position: bottom right;
    display: block;
    transform: scale(1.25) translate(-2.5vw, 5vw);
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    
    #shopify-section-{{ section.id }} .zbd-aff-hero__container {
      flex-direction: column-reverse; /* Puts image on top, card on bottom */
      width: 90vw;
      max-width: 90vw;
      gap: 6vw;
    }

    #shopify-section-{{ section.id }} .zbd-aff-hero__image-col {
      width: 100%;
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .zbd-aff-hero__image {
      max-height: 50vh;
      object-position: center bottom;
    }

    #shopify-section-{{ section.id }} .zbd-aff-hero__card-col {
      width: 100%;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .zbd-aff-hero__card {
      padding: 6vw;
      border-radius: 4vw;
      gap: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-aff-hero__heading { font-size: 6vw; }
    #shopify-section-{{ section.id }} .zbd-aff-hero__heading-highlight { font-size: 6vw; }
    
    #shopify-section-{{ section.id }} .zbd-aff-hero__text { font-size: 4vw; }
    #shopify-section-{{ section.id }} .zbd-aff-hero__author { font-size: 3.5vw; margin-top: 1vw;}
    
    #shopify-section-{{ section.id }} .zbd-aff-hero__button {
      width: 100%;
      border-radius: 8vw;
      padding: 3.5vw 6vw;
      font-size: 4vw;
      margin-top: 2vw;
    }

    #shopify-section-{{ section.id }} .zbd-aff-hero__reviews { gap: 2vw; flex-wrap: wrap; }
    #shopify-section-{{ section.id }} .zbd-aff-hero__stars { height: 4vw; }
    #shopify-section-{{ section.id }} .zbd-aff-hero__reviews-text { font-size: 3.5vw; }

    #shopify-section-{{ section.id }} .zbd-aff-hero__badges-wrapper {
      flex-direction: column;
      align-items: flex-start;
      gap: 3vw;
      margin-top: 2vw;
    }
    #shopify-section-{{ section.id }} .zbd-aff-hero__badge { gap: 2vw; }
    #shopify-section-{{ section.id }} .zbd-aff-hero__badge img { width: 5vw; height: 5vw; }
    #shopify-section-{{ section.id }} .zbd-aff-hero__badge span { font-size: 3.5vw; }
  }
</style>

<div class="zbd-aff-hero__container">
  
  <div class="zbd-aff-hero__card-col">
    <div class="zbd-aff-hero__card">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          
          {%- when 'heading' -%}
            <h1 class="zbd-aff-hero__heading" {{ block.shopify_attributes }}>
              {{ block.settings.heading | escape }}
              {% if block.settings.highlight_text != blank %}
                <span class="zbd-aff-hero__heading-highlight">{{ block.settings.highlight_text | escape }}</span>
              {% endif %}
            </h1>
            
          {%- when 'text' -%}
            <div class="zbd-aff-hero__text-block" {{ block.shopify_attributes }}>
              <div class="zbd-aff-hero__text">
                {{ block.settings.text }}
              </div>
              {%- if block.settings.author_name != blank -%}
                <p class="zbd-aff-hero__author">{{ block.settings.author_name | escape }}</p>
              {%- endif -%}
            </div>
            
          {%- when 'button' -%}
            <a href="{{ block.settings.link | default: '#' }}" class="zbd-aff-hero__button" {{ block.shopify_attributes }}>
              {{ block.settings.label | escape }}
            </a>
            
          {%- when 'reviews' -%}
            <div class="zbd-aff-hero__reviews" {{ block.shopify_attributes }}>
              {%- if block.settings.stars_image != blank -%}
                {{ block.settings.stars_image | image_url: height: 28 | image_tag: class: 'zbd-aff-hero__stars', loading: 'lazy' }}
              {%- else -%}
                <img src="{{ 'zenbud-2026-herostars.png' | asset_url }}" alt="5 Stars Rating" class="zbd-aff-hero__stars" loading="lazy">
              {%- endif -%}
              <span class="zbd-aff-hero__reviews-text">{{ block.settings.text | escape }}</span>
            </div>
            
          {%- when 'trust_badges' -%}
            <div class="zbd-aff-hero__badges-wrapper" {{ block.shopify_attributes }}>
              <div class="zbd-aff-hero__badge">
                {%- if block.settings.icon_1 != blank -%}
                  {{ block.settings.icon_1 | image_url: width: 40 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  <img src="{{ 'zenbud-2026-heroshock.png' | asset_url }}" alt="No electrical shock" loading="lazy">
                {%- endif -%}
                <span>{{ block.settings.text_1 | escape }}</span>
              </div>
              <div class="zbd-aff-hero__badge">
                {%- if block.settings.icon_2 != blank -%}
                  {{ block.settings.icon_2 | image_url: width: 40 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  <img src="{{ 'zenbud-2026-hero90day.png' | asset_url }}" alt="90-Day guarantee" loading="lazy">
                {%- endif -%}
                <span>{{ block.settings.text_2 | escape }}</span>
              </div>
            </div>

        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="zbd-aff-hero__image-col">
    {%- if section.settings.influencer_image != blank -%}
      {{ section.settings.influencer_image | image_url: width: 1200 | image_tag: class: 'zbd-aff-hero__image', loading: 'eager', alt: 'Influencer' }}
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg zbd-aff-hero__image' }}
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "ZenBud Affiliate Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "image_picker",
      "id": "influencer_image",
      "label": "Influencer Image",
      "info": "Upload a cutout image (transparent PNG) or a photo with a black background. It will display on the right side."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 4.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 4.0
    },
    {
      "type": "header",
      "content": "Card Colors"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background Color",
      "default": "#1C1C1C"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#D1D5DB"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight & Button Color",
      "default": "#3A78F2"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Regular Text",
          "default": "Dave Asprey's"
        },
        {
          "type": "text",
          "id": "highlight_text",
          "label": "Highlighted Text",
          "default": "Nervous System Biohack"
        }
      ]
    },
    {
      "type": "text",
      "name": "Quote / Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Quote Text",
          "default": "<p>\"The ZenBud uses ultrasound to stimulate my vagus nerve so I can roll easy into my next event - <u>keeping me grounded, clear, and focused</u>. It works better than electric stimulation <strong>(and doesn't hurt!)</strong>. Plus, it's more affordable.\"</p>"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "DAVE ASPREY",
          "info": "Displays below the quote in the accent color."
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button Label",
          "default": "GET ZENBUD"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        }
      ]
    },
    {
      "type": "reviews",
      "name": "Reviews",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "stars_image",
          "label": "Stars Image",
          "info": "Leave blank to use the default asset."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Review Text",
          "default": "1.2K Reviews • 4.5 Average rating"
        }
      ]
    },
    {
      "type": "trust_badges",
      "name": "Trust Badges",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Badge 1"
        },
        {
          "type": "image_picker",
          "id": "icon_1",
          "label": "Icon 1"
        },
        {
          "type": "text",
          "id": "text_1",
          "label": "Text 1",
          "default": "No electrical shock"
        },
        {
          "type": "header",
          "content": "Badge 2"
        },
        {
          "type": "image_picker",
          "id": "icon_2",
          "label": "Icon 2"
        },
        {
          "type": "text",
          "id": "text_2",
          "label": "Text 2",
          "default": "90-Day money-back guarantee"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud Affiliate Hero",
      "category": "ZenBud Affiliates",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "button"
        },
        {
          "type": "reviews"
        },
        {
          "type": "trust_badges"
        }
      ]
    }
  ]
}
{% endschema %}