{% comment %}
  zenbud-affiliate-feature.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    width: 100vw;
    overflow: hidden;
    display: block;
  }

  #shopify-section-{{ section.id }} .zbd-aff-feat__container {
    width: 85vw;
    max-width: 85vw;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4vw;
  }

  /* Left: Text Column */
  #shopify-section-{{ section.id }} .zbd-aff-feat__text-col {
    flex: 1;
    max-width: 35vw;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .zbd-aff-feat__heading {
    font-size: 2vw; /* ~40px */
    font-weight: 300;
    color: {{ section.settings.text_color }};
    margin: 0 0 2.5vw 0;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .zbd-aff-feat__heading strong,
  #shopify-section-{{ section.id }} .zbd-aff-feat__heading b {
    font-weight: 700;
    display: block;
    font-size: 2vw; /* ~48px */
    margin-top: 0.5vw;
  }

  #shopify-section-{{ section.id }} .zbd-aff-feat__highlight {
    color: {{ section.settings.highlight_color }};
  }

  #shopify-section-{{ section.id }} .zbd-aff-feat__text {
    font-size: 1.04vw; /* ~20px */
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    opacity: 0.9;
    margin-bottom: 2.5vw;
  }

  #shopify-section-{{ section.id }} .zbd-aff-feat__text p {
    margin: 0 0 1.5vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-aff-feat__text p:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .zbd-aff-feat__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.highlight_color }};
    color: #ffffff;
    border-radius: 2.6vw; /* 50px */
    padding: 1vw 2.5vw; /* 18px 40px */
    font-size: 0.83vw; /* 16px */
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: none;
    transition: opacity 0.3s ease, transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .zbd-aff-feat__button:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  /* Right: Image Column */
  #shopify-section-{{ section.id }} .zbd-aff-feat__image-col {
    flex: 1.2;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    position: relative;
  }

  #shopify-section-{{ section.id }} .zbd-aff-feat__image {
    width: 120%; /* Bleed off the right edge */
    max-width: none;
    height: auto;
    object-fit: contain;
    margin-right: -10vw; /* Pull it to the right */
    display: block;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    
    #shopify-section-{{ section.id }} .zbd-aff-feat__container {
      flex-direction: column;
      width: 90vw;
      gap: 8vw;
    }

    #shopify-section-{{ section.id }} .zbd-aff-feat__text-col {
      max-width: 100%;
      align-items: center;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .zbd-aff-feat__heading {
      font-size: 6vw;
      margin-bottom: 6vw;
    }

    #shopify-section-{{ section.id }} .zbd-aff-feat__heading strong,
    #shopify-section-{{ section.id }} .zbd-aff-feat__heading b {
      font-size: 8vw;
      margin-top: 2vw;
    }

    #shopify-section-{{ section.id }} .zbd-aff-feat__text {
      font-size: 4.5vw;
      margin-bottom: 6vw;
    }
    
    #shopify-section-{{ section.id }} .zbd-aff-feat__text p {
      margin-bottom: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-aff-feat__button {
      width: 100%;
      border-radius: 8vw;
      padding: 4vw 6vw;
      font-size: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-aff-feat__image-col {
      width: 100%;
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .zbd-aff-feat__image {
      width: 110%; /* Slight bleed on mobile too */
      margin-right: -5vw;
      margin-left: -5vw;
    }
  }
</style>

<div class="zbd-aff-feat__container">
  
  <div class="zbd-aff-feat__text-col">
    <h2 class="zbd-aff-feat__heading">
      {%- if section.settings.pre_heading != blank -%}
        {{ section.settings.pre_heading | escape }}
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        {%- assign formatted_heading = section.settings.heading | escape -%}
        {%- if section.settings.highlight_word != blank -%}
          {%- assign highlight_span = '<span class="zbd-aff-feat__highlight">' | append: section.settings.highlight_word | append: '</span>' -%}
          {%- assign formatted_heading = formatted_heading | replace: section.settings.highlight_word, highlight_span -%}
        {%- endif -%}
        <strong>{{ formatted_heading }}</strong>
      {%- endif -%}
    </h2>

    {%- if section.settings.text != blank -%}
      <div class="zbd-aff-feat__text">
        {{ section.settings.text }}
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '#' }}" class="zbd-aff-feat__button">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>

  <div class="zbd-aff-feat__image-col">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1400 | image_tag: class: 'zbd-aff-feat__image', loading: 'lazy', alt: section.settings.heading }}
    {%- else -%}
      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg zbd-aff-feat__image' }}
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "ZenBud Affiliate Feature",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight & Button Color",
      "default": "#3A78F2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 8.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 8.0
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Combined Image & Chart",
      "info": "This image is designed to sit on the right and bleed slightly off the edge of the screen."
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "pre_heading",
      "label": "Pre-Heading (Thin)",
      "default": "You Quantify Everything but"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading (Bold)",
      "default": "Are You Optimizing It?"
    },
    {
      "type": "text",
      "id": "highlight_word",
      "label": "Word to Highlight",
      "default": "Optimizing",
      "info": "Type the exact word from the Main Heading above that you want to be blue."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text",
      "default": "<p>You track your sleep, stress, and heart rate variability (HRV), but what if you could actually improve those numbers in real time? ZenBud is the first commercially available wearable that uses ultrasound to stimulate your vagus nerve and unlock a new level of biohacking recovery.</p><p>With just a few minutes a day, you can experience measurable improvements in HRV, deeper calm, and faster stress recovery backed by science and felt within minutes.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "GET ZENBUD"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "ZenBud Affiliate Feature",
      "category": "ZenBud Affiliates"
    }
  ]
}
{% endschema %}