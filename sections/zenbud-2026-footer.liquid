{% comment %}
  zenbud-footer.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    width: 100vw;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    font-family: inherit;
    display: block;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__main {
    width: 85vw;;
    margin: 0 auto;
    padding-top: 5.2vw; /* ~100px */
    padding-bottom: 5.2vw;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    gap: 4vw;
  }

  /* Left Column: Brand & Newsletter */
  #shopify-section-{{ section.id }} .zenbud-footer__brand {
    flex: 0 0 25vw;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__logo {
    width: 15.6vw; /* ~300px */
    height: auto;
    margin-bottom: 3vw;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__social-wrapper {
    display: flex;
    align-items: center;
    gap: 1vw;
    margin-bottom: 3vw;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__social-title {
    font-size: 0.93vw; /* ~18px */
    font-weight: 600;
    margin: 0 0.5vw 0 0;
    color: {{ section.settings.heading_color }};
  }

  #shopify-section-{{ section.id }} .zenbud-footer__social-icons {
    display: flex;
    align-items: center;
    gap: 0.5vw;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__social-icon {
    width: 2.08vw; /* ~40px */
    height: 2.08vw;
    transition: opacity 0.3s ease;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__social-icon:hover {
    opacity: 0.8;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__newsletter {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__newsletter-title {
    font-size: 0.93vw; /* ~18px */
    font-weight: 600;
    margin: 0;
    color: {{ section.settings.heading_color }};
  }

  /* Right Column: Menus */
  #shopify-section-{{ section.id }} .zenbud-footer__menus {
    flex: 1;
    display: flex;
    flex-direction: row;
    justify-content: flex-end;
    gap: 6vw; /* Space between menu columns */
  }

  #shopify-section-{{ section.id }} .zenbud-footer__menu-col {
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__menu-title {
    font-size: 0.93vw; /* ~18px */
    font-weight: 600;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1.5vw 0;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__menu-link {
    font-size: 0.93vw; /* ~18px */
    color: {{ section.settings.text_color }};
    text-decoration: none;
    margin-bottom: 1vw;
    transition: color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__menu-link:hover {
    color: {{ section.settings.heading_color }};
  }

  /* Bottom Copyright Bar */
  #shopify-section-{{ section.id }} .zenbud-footer__bottom {
    background-color: {{ section.settings.bottom_bg_color }};
    color: {{ section.settings.bottom_text_color }};
    padding: 1.5vw 5vw;
    width: 100vw;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__bottom-container {
    width: 85vw;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__bottom p {
    margin: 0;
    font-size: 0.83vw; /* ~16px */
  }

  #shopify-section-{{ section.id }} .zenbud-footer__bottom a {
    color: {{ section.settings.bottom_text_color }};
    text-decoration: underline;
  }

  #shopify-section-{{ section.id }} .zenbud-footer__bottom a:hover {
    opacity: 0.8;
  }

  /* Utility classes for mobile swapping based on the HTML provided */
  .desktop-only { display: flex; }
  .mobile-only { display: none; }

  /* --- Klaviyo Form Override (Inline Pill Design) --- */

/* 1. Make the inner form wrapper relative so we can overlay the button */
.klaviyo-form-VLLqym .needsclick[style*="flex-direction: column"] {
  position: relative !important;
  display: block !important;
  min-height: auto !important;
}

/* 2. Hide the SMS and Disclaimer rows completely */
.klaviyo-form-VLLqym div[data-testid="form-row"]:nth-child(n+3) {
  display: none !important;
}

/* Hide the Email Label */
.klaviyo-form-VLLqym label[for^="email_"] {
  display: none !important;
}

/* 3. Style the Input Field (Full width, grey border, rounded) */
.klaviyo-form-VLLqym input[type="email"] {
  width: 100% !important;
  height: 50px !important;
  padding: 0 130px 0 20px !important; /* Huge right padding so text doesn't hide under button */
  background: #FFFFFF !important;
  border: 1px solid #B3B3B3 !important;
  border-radius: 50px !important;
  font-size: 15px !important;
  color: #333333 !important;
  box-sizing: border-box !important;
  box-shadow: none !important;
}

.klaviyo-form-VLLqym input[type="email"]:focus {
  outline: none !important;
  border-color: #2E62DB !important;
}

/* 4. Position the Button Row absolutely over the right side */
.klaviyo-form-VLLqym div[data-testid="form-row"]:nth-child(2) {
  position: absolute !important;
  top: 10px !important;
  right: 0 !important;
  height: 50px !important;
  width: auto !important;
}

/* Remove Klaviyo's default padding on the button component */
.klaviyo-form-VLLqym div[data-testid="form-row"]:nth-child(2) div[data-testid="form-component"] {
  padding: 0 !important;
  height: 100% !important;
}

/* 5. Style the Blue Submit Button */
.klaviyo-form-VLLqym button {
  height: 50px !important;
  padding: 0 35px !important;
  background-color: #2E62DB !important; /* Blue matching mockup */
  color: #FFFFFF !important;
  border-radius: 50px !important;
  font-size: 15px !important;
  font-weight: 700 !important;
  text-transform: capitalize !important; /* Forces "Submit" instead of "SUBMIT" */
  border: none !important;
  cursor: pointer !important;
  transition: background-color 0.3s ease !important;
  margin: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.klaviyo-form-VLLqym button:hover {
  background-color: #285ec4 !important;
}

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    .desktop-only { display: none !important; }
    .mobile-only { display: flex !important; flex-direction: column; margin-top: 6vw; }

    #shopify-section-{{ section.id }} .zenbud-footer__main {
      flex-direction: column;
      padding-top: 12vw;
      padding-bottom: 12vw;
      gap: 10vw;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__brand {
      width: 100%;
      flex: none;
      align-items: center;
      text-align: center;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__logo {
      width: 50vw;
      margin-bottom: 6vw;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__social-wrapper {
      flex-direction: column;
      gap: 3vw;
      margin-bottom: 8vw;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__social-title {
      font-size: 4.5vw;
      margin: 0;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__social-icon {
      width: 10vw;
      height: 10vw;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__newsletter-title {
      font-size: 4.5vw;
      margin-bottom: 4vw;
    }
    
    #shopify-section-{{ section.id }} .zenbud-footer__menus {
      flex-direction: column;
      justify-content: flex-start;
      gap: 8vw;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__menu-col {
      align-items: center;
      text-align: center;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__menu-title {
      font-size: 5vw;
      margin-bottom: 4vw;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__menu-link {
      font-size: 4vw;
      margin-bottom: 3vw;
    }

    #shopify-section-{{ section.id }} .zenbud-footer__bottom {
      padding: 6vw 5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__bottom-container {
      flex-direction: column;
      gap: 4vw;
      text-align: center;
    }
    #shopify-section-{{ section.id }} .zenbud-footer__bottom p {
      font-size: 3.5vw;
    }
  }

  @media screen and (min-width: 767px) and (max-width: 1023px) {

    #shopify-section-{{ section.id }} .zenbud-footer__main { 
      max-width: 90vw;
      width: 90vw;
    }

    #shopify-section-{{ section.id }} .zenbud-footer__social-title {
      font-size: 1.5vw;
    }

    #shopify-section-{{ section.id }} .zenbud-footer__menu-title {
      font-size: 1.5vw;
    }

    #shopify-section-{{ section.id }} .zenbud-footer__menu-link {
      font-size: 1.5vw;
    }

    #shopify-section-{{ section.id }} .zenbud-footer__bottom p {
      font-size: 1.5vw;
    }

    #shopify-section-{{ section.id }} .zenbud-footer__newsletter-title {
      font-size: 1.5vw;
    }

    .klaviyo-form.klaviyo-form.klaviyo-form {
      padding: 0 !important;
  }

    .klaviyo-form-VLLqym div[data-testid="form-row"] {
      padding: 0 !important;
    }

    .klaviyo-form-VLLqym div[data-testid="form-row"]:nth-child(2) {
        position: relative !important;
        top: 0;
        right: 0 !important;
        height: 50px !important;
        width: auto !important;
    }

  }
</style>

<div class="zenbud-footer__main">
  
  <div class="zenbud-footer__brand">
    <a href="{{ routes.root_url }}">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 400 | image_tag: class: 'zenbud-footer__logo', loading: 'lazy', alt: shop.name }}
      {%- else -%}
        <img src="{{ 'zbd-footer-logo.png' | asset_url }}" class="zenbud-footer__logo" alt="ZenBud Logo" loading="lazy">
      {%- endif -%}
    </a>

    <div class="zenbud-footer__social-wrapper">
      <h3 class="zenbud-footer__social-title">{{ section.settings.social_title | escape }}</h3>
      <div class="zenbud-footer__social-icons">
        {%- if section.settings.social_fb != blank -%}
          <a href="{{ section.settings.social_fb }}" aria-label="Follow us on Facebook" target="_blank">
            <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/zenbud-footer-fb.png?v=1778546190" class="zenbud-footer__social-icon" alt="Facebook">
          </a>
        {%- endif -%}
        {%- if section.settings.social_ig != blank -%}
          <a href="{{ section.settings.social_ig }}" aria-label="Follow us on Instagram" target="_blank">
            <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/zenbud-footer-insta.png?v=1778546190" class="zenbud-footer__social-icon" alt="Instagram">
          </a>
        {%- endif -%}
        {%- if section.settings.social_yt != blank -%}
          <a href="{{ section.settings.social_yt }}" aria-label="Follow us on YouTube" target="_blank">
            <img src="{{ 'youtube-icon.png' | asset_url }}" class="zenbud-footer__social-icon" alt="YouTube">
          </a>
        {%- endif -%}
        {%- if section.settings.social_tt != blank -%}
          <a href="{{ section.settings.social_tt }}" aria-label="Follow us on TikTok" target="_blank">
            <img src="https://cdn.shopify.com/s/files/1/0858/0713/7087/files/tiktok_11556b21-a0c0-42bf-8c84-d4522b7e7c15.png?v=1779401172" class="zenbud-footer__social-icon" alt="TikTok">
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="zenbud-footer__newsletter">
      <h3 class="zenbud-footer__newsletter-title">{{ section.settings.newsletter_title | escape }}</h3>
      <div class="{{ section.settings.klaviyo_class }}"></div>
    </div>
  </div>

  <div class="zenbud-footer__menus">
    
    <div class="zenbud-footer__menu-col">
      <h3 class="zenbud-footer__menu-title">{{ section.settings.menu_1_title | escape }}</h3>
      {%- if section.settings.menu_1 != blank -%}
        {%- for link in linklists[section.settings.menu_1].links -%}
          <a href="{{ link.url }}" class="zenbud-footer__menu-link">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/products/zenbud-series-2" class="zenbud-footer__menu-link">Device</a>
        <a href="/pages/financing" class="zenbud-footer__menu-link">Financing</a>
      {%- endif -%}

      <div class="mobile-only">
        <h3 class="zenbud-footer__menu-title" style="margin-top: 4vw;">{{ section.settings.menu_3_title | escape }}</h3>
        {%- if section.settings.menu_3 != blank -%}
          {%- for link in linklists[section.settings.menu_3].links -%}
            <a href="{{ link.url }}" class="zenbud-footer__menu-link">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="/blogs/news" class="zenbud-footer__menu-link">Research Library</a>
          <a href="/pages/safety-compliance" class="zenbud-footer__menu-link">Safety & Compliance</a>
          <a href="/pages/website-product-disclaimer" class="zenbud-footer__menu-link">Disclaimers</a>
        {%- endif -%}
      </div>
    </div>

    <div class="zenbud-footer__menu-col">
      <h3 class="zenbud-footer__menu-title">{{ section.settings.menu_2_title | escape }}</h3>
      {%- if section.settings.menu_2 != blank -%}
        {%- for link in linklists[section.settings.menu_2].links -%}
          <a href="{{ link.url }}" class="zenbud-footer__menu-link">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/pages/faqs" class="zenbud-footer__menu-link">FAQ</a>
        <a href="/policies/shipping-policy" class="zenbud-footer__menu-link">Shipping</a>
        <a href="/pages/90-day-money-back-guarantee" class="zenbud-footer__menu-link">90-Day Guarantee</a>
        <a href="/pages/warranty" class="zenbud-footer__menu-link">1-Year Warranty</a>
        <a href="/policies/refund-policy" class="zenbud-footer__menu-link">Returns</a>
        <a href="/pages/contact" class="zenbud-footer__menu-link">Contact</a>
        <a href="/pages/hsa-fsa" class="zenbud-footer__menu-link">HSA/FSA</a>
      {%- endif -%}
    </div>

    <div class="zenbud-footer__menu-col desktop-only">
      <h3 class="zenbud-footer__menu-title">{{ section.settings.menu_3_title | escape }}</h3>
      {%- if section.settings.menu_3 != blank -%}
        {%- for link in linklists[section.settings.menu_3].links -%}
          <a href="{{ link.url }}" class="zenbud-footer__menu-link">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/pages/research-library" class="zenbud-footer__menu-link">Research Library</a>
        <a href="/pages/safety-compliance" class="zenbud-footer__menu-link">Safety & Compliance</a>
        <a href="/pages/website-product-disclaimer" class="zenbud-footer__menu-link">Disclaimers</a>
      {%- endif -%}
    </div>

    <div class="zenbud-footer__menu-col">
      <h3 class="zenbud-footer__menu-title">{{ section.settings.menu_4_title | escape }}</h3>
      {%- if section.settings.menu_4 != blank -%}
        {%- for link in linklists[section.settings.menu_4].links -%}
          <a href="{{ link.url }}" class="zenbud-footer__menu-link">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="/pages/about" class="zenbud-footer__menu-link">About</a>
        <a href="https://partners.zenbud.health/" class="zenbud-footer__menu-link">Become a Partner</a>
      {%- endif -%}
    </div>

  </div>
</div>

<div class="zenbud-footer__bottom">
  <div class="zenbud-footer__bottom-container">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.</p>
    <p><strong>Built By <a href="https://ryzeagency.com/" target="_blank" rel="noopener">Ryze Agency</a></strong></p>
  </div>
</div>

