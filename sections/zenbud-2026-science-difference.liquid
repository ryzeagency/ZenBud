{% comment %}
  zenbud-science-grid.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    width: 100vw;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .zbd-sci-grid__container {
    width: 90vw;
    max-width: 75vw; /* ~1440px */
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  /* Top Heading */
  #shopify-section-{{ section.id }} .zbd-sci-grid__heading {
    font-size: 1.87vw; /* ~36px */
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin: 0 0 3vw 0;
    line-height: 1.2;
  }

  /* CSS Grid for Cards */
  #shopify-section-{{ section.id }} .zbd-sci-grid__cards {
    display: grid;
    /* Automatically creates columns based on block count, defaults to 4 */
    grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
    gap: 1.5vw;
    margin-bottom: 3vw;
  }

  /* Individual Card */
  #shopify-section-{{ section.id }} .zbd-sci-grid__card {
    background-color: {{ section.settings.card_bg_color }};
    border-radius: 1.2vw; /* ~24px */
    padding: 2.5vw; /* ~48px */
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .zbd-sci-grid__card-title {
    font-size: 1.25vw; /* ~24px */
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-sci-grid__card-text {
    font-size: 0.83vw; /* ~16px */
    line-height: 1.5;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  /* Bottom Text */
  #shopify-section-{{ section.id }} .zbd-sci-grid__footer-text {
    font-size: 0.93vw; /* ~18px */
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    max-width: 90%;
  }

  #shopify-section-{{ section.id }} .zbd-sci-grid__footer-text p {
    margin: 0 0 1.5vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-sci-grid__footer-text p:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .zbd-sci-grid__footer-text strong {
    font-weight: 700;
    color: {{ section.settings.heading_color }};
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    
    #shopify-section-{{ section.id }} .zbd-sci-grid__container {
      width: 90vw;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .zbd-sci-grid__heading {
      font-size: 7vw;
      margin-bottom: 6vw;
    }

    #shopify-section-{{ section.id }} .zbd-sci-grid__cards {
      grid-template-columns: 1fr; /* Stack cards vertically on mobile */
      gap: 4vw;
      margin-bottom: 8vw;
    }

    #shopify-section-{{ section.id }} .zbd-sci-grid__card {
      border-radius: 4vw;
      padding: 6vw;
    }

    #shopify-section-{{ section.id }} .zbd-sci-grid__card-title {
      font-size: 5vw;
      margin-bottom: 3vw;
    }

    #shopify-section-{{ section.id }} .zbd-sci-grid__card-text {
      font-size: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-sci-grid__footer-text {
      font-size: 4vw;
      max-width: 100%;
    }
    
    #shopify-section-{{ section.id }} .zbd-sci-grid__footer-text p {
      margin-bottom: 4vw;
    }
  }
</style>

<div class="zbd-sci-grid__container">
  
  {%- if section.settings.heading != blank -%}
    <h2 class="zbd-sci-grid__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="zbd-sci-grid__cards">
    {%- for block in section.blocks -%}
      <div class="zbd-sci-grid__card" {{ block.shopify_attributes }}>
        {%- if block.settings.title != blank -%}
          <h3 class="zbd-sci-grid__card-title">{{ block.settings.title | escape }}</h3>
        {%- endif -%}
        
        {%- if block.settings.text != blank -%}
          <p class="zbd-sci-grid__card-text">{{ block.settings.text | escape }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.bottom_text != blank -%}
    <div class="zbd-sci-grid__footer-text">
      {{ section.settings.bottom_text }}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "ZenBud Science Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#2A2A2A"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#E0E0E0"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 8.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 8.0
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "What Makes Ultrasound Different"
    },
    {
      "type": "richtext",
      "id": "bottom_text",
      "label": "Bottom Footer Text",
      "default": "<p>In ZenBud, these gentle waves are delivered in short 5-minute sessions to help your nervous system \"reset\" faster and more effectively than conventional stimulation methods.</p><p><strong>In short: ZenBud transforms decades of neuromodulation science into an effortless, non-invasive daily practice for calm.</strong></p>"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Feature Card",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Feature"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Card Description",
          "default": "Description of this feature goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud Science Grid",
      "category": "Zenbud Science",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Precision",
            "text": "Ultrasound can be focused directly on nerve fibers for consistent results."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Comfort",
            "text": "It's completely non-electrical—no shocks, no tingles."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Depth",
            "text": "It reaches where electrical or vibration devices can't, without breaking the skin or requiring invasive procedures."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Safety",
            "text": "The same frequency range has been used safely in medical imaging for over 50 years."
          }
        }
      ]
    }
  ]
}
{% endschema %}