{% comment %}
  zenbud-product-reviews.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    width: 100vw;
  }

  #shopify-section-{{ section.id }} .zbd-reviews__container {
    width: 90vw;
    max-width: 75vw; /* ~1440px */
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Header Styles */
  #shopify-section-{{ section.id }} .zbd-reviews__header {
    text-align: center;
    margin-bottom: 3vw;
  }

  #shopify-section-{{ section.id }} .zbd-reviews__subheading {
    font-size: 0.93vw; /* ~18px */
    font-weight: 800;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin: 0 0 0.5vw 0;
    letter-spacing: 0.05em;
  }

  #shopify-section-{{ section.id }} .zbd-reviews__heading {
    font-size: 2.08vw; /* ~40px */
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }

  /* Widget Wrapper */
  #shopify-section-{{ section.id }} .zbd-reviews__widget-wrapper {
    width: 100%;
    /* Constrain the judge.me widget so it doesn't stretch too wide on huge screens */
    max-width: 1000px; 
    margin: 0 auto;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    #shopify-section-{{ section.id }} .zbd-reviews__container {
      width: 90vw;
      max-width: 100%;
    }
    #shopify-section-{{ section.id }} .zbd-reviews__header {
      margin-bottom: 8vw;
    }
    #shopify-section-{{ section.id }} .zbd-reviews__subheading {
      font-size: 4vw;
      margin-bottom: 2vw;
    }
    #shopify-section-{{ section.id }} .zbd-reviews__heading {
      font-size: 7vw;
    }
  }
</style>

<div class="zbd-reviews__container">
  
  <div class="zbd-reviews__header">
    {%- if section.settings.subheading != blank -%}
      <h3 class="zbd-reviews__subheading">{{ section.settings.subheading | escape }}</h3>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="zbd-reviews__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
  </div>

  <div class="zbd-reviews__widget-wrapper">
    <div style='clear:both'></div>
    <div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ product.title | escape }}' data-id='{{ product.id }}' data-auto-install='false'>
      {{ product.metafields.judgeme.widget }}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "ZenBud Product Reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Subheading)",
      "default": "#2E62DB"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 6.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 8.0
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "TESTIMONIALS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "What people love about ZenBud"
    }
  ],
  "presets": [
    {
      "name": "ZenBud Product Reviews",
      "category": "ZenBud Product"
    }
  ]
}
{% endschema %}