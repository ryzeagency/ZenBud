{% comment %}
  zenbud-about-hero.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100vw;
    min-height: {{ section.settings.desktop_min_height }}vh;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Desktop Background Image */
  #shopify-section-{{ section.id }} .zbd-simple-hero__bg-desktop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    pointer-events: none;
  }

  /* Mobile Background Image */
  #shopify-section-{{ section.id }} .zbd-simple-hero__bg-mobile {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    pointer-events: none;
    display: none; /* Hidden on desktop */
  }

  /* Content Wrapper */
  #shopify-section-{{ section.id }} .zbd-simple-hero__container {
    position: relative;
    z-index: 2;
    width: 85vw;
    max-width: 85vw; /* ~1440px */
    margin: 0 auto;
    display: flex;
  }

  /* Push the text box left, center, or right */
  {% if section.settings.content_position == 'right' %}
    #shopify-section-{{ section.id }} .zbd-simple-hero__container { justify-content: flex-end; }
  {% elsif section.settings.content_position == 'center' %}
    #shopify-section-{{ section.id }} .zbd-simple-hero__container { justify-content: center; }
  {% else %}
    #shopify-section-{{ section.id }} .zbd-simple-hero__container { justify-content: flex-start; }
  {% endif %}

  /* The actual text container */
  #shopify-section-{{ section.id }} .zbd-simple-hero__text-box {
    width: 100%;
    max-width: 40vw; /* Keeps the text from spanning the whole screen */
    text-align: {{ section.settings.text_alignment }};
  }

  #shopify-section-{{ section.id }} .zbd-simple-hero__heading {
    font-size: 2.5vw; /* ~48px */
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1vw 0;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .zbd-simple-hero__text {
    font-size: 1.04vw; /* ~20px */
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      min-height: {{ section.settings.mobile_min_height }}vh;
      padding-top: calc({{ section.settings.padding_top }}vw * 2.5);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 2.5);
      align-items: center; /* Centers text vertically on mobile */
    }

    #shopify-section-{{ section.id }} .zbd-simple-hero__bg-desktop {
      display: none;
    }
    
    #shopify-section-{{ section.id }} .zbd-simple-hero__bg-mobile {
      display: block;
    }
    
    #shopify-section-{{ section.id }} .zbd-simple-hero__container {
      width: 90vw;
      justify-content: center; /* Always center content box on mobile */
    }

    #shopify-section-{{ section.id }} .zbd-simple-hero__text-box {
      max-width: 100%;
      text-align: center; /* Always center text on mobile */
    }

    #shopify-section-{{ section.id }} .zbd-simple-hero__heading {
      font-size: 8vw;
      margin-bottom: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-simple-hero__text {
      font-size: 4.5vw;
    }
  }
</style>

{%- if section.settings.bg_image_desktop != blank -%}
  {{ section.settings.bg_image_desktop | image_url: width: 2400 | image_tag: class: 'zbd-simple-hero__bg-desktop', loading: 'eager', alt: 'Desktop Background' }}
{%- endif -%}

{%- if section.settings.bg_image_mobile != blank -%}
  {{ section.settings.bg_image_mobile | image_url: width: 1000 | image_tag: class: 'zbd-simple-hero__bg-mobile', loading: 'eager', alt: 'Mobile Background' }}
{%- endif -%}

<div class="zbd-simple-hero__container">
  <div class="zbd-simple-hero__text-box">
    {%- if section.settings.heading != blank -%}
      <h1 class="zbd-simple-hero__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="zbd-simple-hero__text">{{ section.settings.text | escape }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "ZenBud About Hero (Bg)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fallback Background Color",
      "default": "#FAFAFA"
    },
    {
      "type": "image_picker",
      "id": "bg_image_desktop",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Mobile Background Image"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#4A4A4A"
    },
    {
      "type": "range",
      "id": "desktop_min_height",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Desktop Minimum Height",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_min_height",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Mobile Minimum Height",
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 8.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 8.0
    },
    {
      "type": "header",
      "content": "Layout & Alignment"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Text Box Position (Desktop)",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "right",
      "info": "Moves the text block to dodge the focal point of your background image."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "info": "Aligns the actual text inside the content box."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story & Purpose"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text",
      "default": "From research to real life—how ZenBud makes well-being simpler."
    }
  ],
  "presets": [
    {
      "name": "ZenBud About Hero (Bg)",
      "category": "ZenBud About"
    }
  ]
}
{% endschema %}