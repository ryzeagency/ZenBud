{% comment %}
  zenbud-about-hero.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    width: 100vw;
    overflow: hidden;
    display: block;
    position: relative; 
  }

  /* Desktop Background Image */
  #shopify-section-{{ section.id }} .zbd-about-hero__bg-desktop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    pointer-events: none;
  }

  /* Mobile Background Image */
  #shopify-section-{{ section.id }} .zbd-about-hero__bg-mobile {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    pointer-events: none;
    display: none; 
  }

  #shopify-section-{{ section.id }} .zbd-about-hero__container {
    position: relative;
    z-index: 2;
    width: 85vw;
    max-width: 85vw; /* ~1440px */
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6vw;
    min-height: {{ section.settings.desktop_min_height }}vh; /* Forces height when empty */
  }

  /* Reverses column order if selected in settings */
  #shopify-section-{{ section.id }} .zbd-about-hero__container--reverse {
    flex-direction: row-reverse;
  }

  /* Left: Image Column */
  #shopify-section-{{ section.id }} .zbd-about-hero__img-col {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zbd-about-hero__img-col img {
    width: 100%;
    max-width: 35vw; 
    height: auto;
    object-fit: contain;
  }

  /* Right: Text Column */
  #shopify-section-{{ section.id }} .zbd-about-hero__text-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: {{ section.settings.text_alignment }}; /* Controls the actual text alignment */
  }

  /* Dynamic Alignment for the text block container */
  {% if section.settings.content_position == 'center' %}
    #shopify-section-{{ section.id }} .zbd-about-hero__text-col {
      align-items: center;
    }
  {% elsif section.settings.content_position == 'right' %}
    #shopify-section-{{ section.id }} .zbd-about-hero__text-col {
      align-items: flex-end;
    }
  {% else %}
    #shopify-section-{{ section.id }} .zbd-about-hero__text-col {
      align-items: flex-start;
    }
  {% endif %}

  #shopify-section-{{ section.id }} .zbd-about-hero__heading {
    font-size: 2.5vw; /* ~48px */
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1vw 0;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .zbd-about-hero__text {
    font-size: 1.04vw; /* ~20px */
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin: 0;
    max-width: 85%;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 2.5);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 2.5);
    }

    #shopify-section-{{ section.id }} .zbd-about-hero__bg-desktop {
      display: none;
    }
    
    #shopify-section-{{ section.id }} .zbd-about-hero__bg-mobile {
      display: block;
    }
    
    #shopify-section-{{ section.id }} .zbd-about-hero__container,
    #shopify-section-{{ section.id }} .zbd-about-hero__container--reverse {
      flex-direction: column;
      width: 90vw;
      max-width: 100%;
      gap: 8vw;
      text-align: center;
      min-height: auto; /* Let content dictate height on mobile */
    }

    #shopify-section-{{ section.id }} .zbd-about-hero__img-col img {
      max-width: 80vw;
    }

    #shopify-section-{{ section.id }} .zbd-about-hero__text-col {
      align-items: center;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .zbd-about-hero__heading {
      font-size: 8vw;
      margin-bottom: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-about-hero__text {
      font-size: 4.5vw;
      max-width: 100%;
    }
  }
</style>

{%- if section.settings.bg_image_desktop != blank -%}
  {{ section.settings.bg_image_desktop | image_url: width: 2400 | image_tag: class: 'zbd-about-hero__bg-desktop', loading: 'lazy', alt: 'Desktop Background' }}
{%- endif -%}

{%- if section.settings.bg_image_mobile != blank -%}
  {{ section.settings.bg_image_mobile | image_url: width: 1000 | image_tag: class: 'zbd-about-hero__bg-mobile', loading: 'lazy', alt: 'Mobile Background' }}
{%- endif -%}

<div class="zbd-about-hero__container {% if section.settings.image_position == 'right' %}zbd-about-hero__container--reverse{% endif %}">
  
  {%- if section.settings.image != blank -%}
    <div class="zbd-about-hero__img-col">
      {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.heading }}
    </div>
  {%- endif -%}

  <div class="zbd-about-hero__text-col">
    {%- if section.settings.heading != blank -%}
      <h1 class="zbd-about-hero__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="zbd-about-hero__text">{{ section.settings.text | escape }}</p>
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "ZenBud About Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAFAFA"
    },
    {
      "type": "image_picker",
      "id": "bg_image_desktop",
      "label": "Desktop Background Image"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Mobile Background Image"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#4A4A4A"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 8.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 8.0
    },
    {
      "type": "range",
      "id": "desktop_min_height",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Desktop Minimum Height",
      "default": 60,
      "info": "Prevents the section from shrinking too small if you don't use a side image."
    },
    {
      "type": "header",
      "content": "Layout & Alignment"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Desktop Image Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "info": "Swaps the image and text column order."
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Box Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "info": "Moves the entire text block left or right within its column."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "info": "Aligns the actual text inside the content box."
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image",
      "info": "Leave blank to hide the image and display a full-width text section."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story & Purpose"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text",
      "default": "From research to real life—how ZenBud makes well-being simpler."
    }
  ],
  "presets": [
    {
      "name": "ZenBud About Hero",
      "category": "ZenBud About"
    }
  ]
}
{% endschema %}