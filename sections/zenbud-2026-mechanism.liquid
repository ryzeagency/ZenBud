{% comment %}
  zenbud-mechanism.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100vw;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    overflow: hidden;
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__container {
    width: 90vw;
    display: flex;
    flex-direction: column;
    gap: 3.12vw; /* ~60px */
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__header {
    display: flex;
    flex-direction: column;
    gap: 0.52vw; /* ~10px */
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__subheading {
    font-size: 0.83vw; /* ~16px */
    color: {{ section.settings.subheading_color }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__heading {
    font-size: 1.87vw; /* ~36px */
    color: {{ section.settings.heading_color }};
    margin: 0;
    font-weight: 700;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__steps {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    gap: 2.08vw; /* ~40px */
    width: 100%;
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__step {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.04vw; /* ~20px */
    flex: 1 1 0%;
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__icon-wrapper {
    flex-shrink: 0;
    width: 3.33vw; /* ~64px */
    height: 3.33vw; /* ~64px */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__icon-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__text-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.2vw; /* ~4px */
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__step-title {
    font-size: 1.04vw; /* ~20px */
    color: {{ section.settings.text_color }};
    margin: 0;
    font-weight: 700;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .zenbud-mechanism__step-text {
    font-size: 0.83vw; /* ~16px */
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: 1.4;
  }

  /* Responsive styling for mobile devices */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    #shopify-section-{{ section.id }} .zenbud-mechanism__container {
      gap: 8vw;
    }
    #shopify-section-{{ section.id }} .zenbud-mechanism__header {
      gap: 2vw;
    }
    #shopify-section-{{ section.id }} .zenbud-mechanism__subheading {
      font-size: 3.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-mechanism__heading {
      font-size: 7vw;
    }
    #shopify-section-{{ section.id }} .zenbud-mechanism__steps {
      flex-direction: column;
      gap: 6vw;
    }
    #shopify-section-{{ section.id }} .zenbud-mechanism__step {
      gap: 4vw;
      align-items: flex-start;
    }
    #shopify-section-{{ section.id }} .zenbud-mechanism__icon-wrapper {
      width: 10vw;
      height: 10vw;
    }
    #shopify-section-{{ section.id }} .zenbud-mechanism__text-wrapper {
      gap: 1vw;
    }
    #shopify-section-{{ section.id }} .zenbud-mechanism__step-title {
      font-size: 4.5vw;
    }
    #shopify-section-{{ section.id }} .zenbud-mechanism__step-text {
      font-size: 3.5vw;
    }
  }
</style>

<div class="zenbud-mechanism__container">
  <div class="zenbud-mechanism__header">
    {%- if section.settings.subheading != blank -%}
      <p class="zenbud-mechanism__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="zenbud-mechanism__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="zenbud-mechanism__steps">
      {%- for block in section.blocks -%}
        <div class="zenbud-mechanism__step" {{ block.shopify_attributes }}>
          <div class="zenbud-mechanism__icon-wrapper">
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 100 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- else -%}
              {%- capture fallback_icon -%}zenbud-icon-step-{{ forloop.index }}.png{%- endcapture -%}
              <img src="{{ fallback_icon | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="zenbud-mechanism__text-wrapper">
            {%- if block.settings.title != blank -%}
              <h3 class="zenbud-mechanism__step-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="zenbud-mechanism__step-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "ZenBud Mechanism",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2E62DB"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Step Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 5.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 5.0
    },
    {
      "type": "header",
      "content": "Header Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "THE MECHANISM"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How ZenBud Works"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Mechanism Step",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Step Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Step description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud Mechanism",
      "category": "Home Revamp",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "You put it on",
            "text": "Headset over your ears · 20 sec setup"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Start your session",
            "text": "Ultrasound reaches your vagus nerve"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Parasympathetic response activates",
            "text": "Heart rate settles · tension eases"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "HRV improves over time",
            "text": "Track it on Oura · Apple Watch · Garmin"
          }
        }
      ]
    }
  ]
}
{% endschema %}