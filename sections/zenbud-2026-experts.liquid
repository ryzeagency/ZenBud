{% comment %}
  zenbud-experts.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100vw;
    background-color: {{ section.settings.page_bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .zenbud-experts__container {
    width: 75vw; /* 75% container width on desktop as requested */
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zenbud-experts__heading {
    font-size: 1.56vw; /* ~30px */
    font-weight: 300;
    color: {{ section.settings.heading_color }};
    margin: 0 0 5.2vw 0; /* ~100px */
    text-align: center;
  }

  #shopify-section-{{ section.id }} .zenbud-experts__grid {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    width: 100%;
    gap: 2.08vw; /* ~40px */
  }

  #shopify-section-{{ section.id }} .zenbud-experts__card {
    position: relative;
    flex: 1 1 0%;
    background-color: {{ section.settings.card_bg_color }};
    border-radius: 1.56vw; /* ~30px */
    width: 31%;
    box-shadow: 0 1.04vw 2.08vw rgba(0, 0, 0, 0.08);
    padding-bottom: 10vw;
    /* Intentionally omitting overflow: hidden so the image can break out the top */
  }

  /* The transparent PNG image */
  #shopify-section-{{ section.id }} .zenbud-experts__image {
    width: 100%;
    height: auto;
    /* Round the bottom corners to match the card, but leave the top flat to overflow */
    border-bottom-left-radius: 1.56vw;
    border-bottom-right-radius: 1.56vw;
    z-index: 1;
    pointer-events: none;
    object-fit: contain;
    object-position: bottom center;
    margin-top: -5vw;
  }

  /* The frosted glass / mirror overlay at the bottom */
  #shopify-section-{{ section.id }} .zenbud-experts__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    min-height: 35%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2.08vw 1.56vw;
    background-color: transparent;
    backdrop-filter: blur(1.56vw) brightness(0.15);
    -webkit-backdrop-filter: blur(1.56vw) brightness(0.15);
    border-radius: 1.56vw;
    overflow: hidden;
    z-index: 2;
    background: rgba(255,255,255,0.2);
  }

  /* White blur soft spots */
  #shopify-section-{{ section.id }} .zenbud-experts__spot {
    position: absolute;
    bottom: -5vw; /* ~-50px */
    width: 8.33vw; /* ~160px */
    height: 8.33vw; /* ~160px */
    background-color: rgba(255, 255, 255, 0.5);
    filter: blur(2.6vw); /* ~50px */
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .zenbud-experts__spot--left {
    left: -5vw;
  }

  #shopify-section-{{ section.id }} .zenbud-experts__spot--right {
    right: -5vw;
  }

  /* Text Wrapper to sit above the soft spots */
  #shopify-section-{{ section.id }} .zenbud-experts__content {
    position: relative;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .zenbud-experts__name {
    font-size: 1.14vw; /* ~22px */
    font-weight: 400;
    color: #ffffff;
    margin: 0 0 0.2vw 0; /* ~4px */
  }

  #shopify-section-{{ section.id }} .zenbud-experts__role {
    font-size: 0.73vw; /* ~14px */
    font-weight: 400;
    color: #c4c4c4;
    margin: 0 0 1.04vw 0; /* ~20px */
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .zenbud-experts__quote {
    font-size: 0.67vw; /* ~13px */
    font-weight: 400;
    color: #ffffff;
    margin: 0;
    line-height: 1.5;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    #shopify-section-{{ section.id }} .zenbud-experts__container {
      width: 90vw;
    }
    #shopify-section-{{ section.id }} .zenbud-experts__heading {
      font-size: 5vw;
      margin-bottom: 12vw;
      padding: 0 4vw;
    }
    #shopify-section-{{ section.id }} .zenbud-experts__grid {
      flex-direction: column;
      gap: 15vw; /* Large gap because images pop out of the top of the cards */
    }
    #shopify-section-{{ section.id }} .zenbud-experts__card {
      width: 100%;
      border-radius: 6vw;
      aspect-ratio: 0.75;
    }
    #shopify-section-{{ section.id }} .zenbud-experts__image {
      border-bottom-left-radius: 6vw;
      border-bottom-right-radius: 6vw;
    }
    #shopify-section-{{ section.id }} .zenbud-experts__overlay {
      padding: 6vw 5vw;
      border-bottom-left-radius: 6vw;
      border-bottom-right-radius: 6vw;
      backdrop-filter: blur(4vw) brightness(0.15);
      -webkit-backdrop-filter: blur(4vw) brightness(0.15);
    }
    #shopify-section-{{ section.id }} .zenbud-experts__spot {
      width: 25vw;
      height: 25vw;
      filter: blur(8vw);
      bottom: -8vw;
    }
    #shopify-section-{{ section.id }} .zenbud-experts__spot--left {
      left: -8vw;
    }
    #shopify-section-{{ section.id }} .zenbud-experts__spot--right {
      right: -8vw;
    }
    #shopify-section-{{ section.id }} .zenbud-experts__name {
      font-size: 6vw;
      margin-bottom: 1vw;
    }
    #shopify-section-{{ section.id }} .zenbud-experts__role {
      font-size: 3.5vw;
      margin-bottom: 4vw;
    }
    #shopify-section-{{ section.id }} .zenbud-experts__quote {
      font-size: 3.5vw;
    }
  }
</style>

<div class="zenbud-experts__container">
  {%- if section.settings.heading != blank -%}
    <h2 class="zenbud-experts__heading h3">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="zenbud-experts__grid">
    {%- for block in section.blocks -%}
      <div class="zenbud-experts__card" {{ block.shopify_attributes }}>
        
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 800 | image_tag: class: 'zenbud-experts__image', loading: 'lazy', alt: block.settings.name }}
        {%- else -%}
          {%- capture fallback_img -%}expert-{{ forloop.index }}.png{%- endcapture -%}
          <img src="{{ fallback_img | asset_url }}" alt="{{ block.settings.name | escape }}" class="zenbud-experts__image" loading="lazy">
        {%- endif -%}

        <div class="zenbud-experts__overlay">
          <!-- Soft Blur Highlights -->
          <div class="zenbud-experts__spot zenbud-experts__spot--left"></div>
          <div class="zenbud-experts__spot zenbud-experts__spot--right"></div>
          
          <div class="zenbud-experts__content">
            {%- if block.settings.name != blank -%}
              <h3 class="zenbud-experts__name">{{ block.settings.name | escape }}</h3>
            {%- endif -%}
            
            {%- if block.settings.role != blank -%}
              <p class="zenbud-experts__role">{{ block.settings.role | escape }}</p>
            {%- endif -%}
            
            {%- if block.settings.quote != blank -%}
              <p class="zenbud-experts__quote">{{ block.settings.quote | escape }}</p>
            {%- endif -%}
          </div>
        </div>

      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "ZenBud Experts",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "page_bg_color",
      "label": "Page Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#2E2E2E",
      "info": "The dark color behind the person."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 8.0,
      "info": "Increased top padding is recommended to prevent clipping the popping heads."
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 5.0
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Trusted by top experts in performance"
    }
  ],
  "blocks": [
    {
      "type": "expert",
      "name": "Expert Card",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Expert Image",
          "info": "For the pop-out effect, upload a tall portrait image with a transparent background. The image will naturally break out of the top of the card."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Expert Name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Title / Role",
          "default": "Expert Title"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "“Insert a quote here.”"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud Experts",
      "category": "Home Revamp",
      "blocks": [
        {
          "type": "expert",
          "settings": {
            "name": "Dave Asprey",
            "role": "Father of Biohacking",
            "quote": "“The ZenBud uses ultrasound to stimulate my vagus nerve so I can roll easy into my next event - keeping me grounded, clear, and focused.”"
          }
        },
        {
          "type": "expert",
          "settings": {
            "name": "Christine Smith",
            "role": "Functional Medicine Practitioner and Doctor of Chiropractic",
            "quote": "“Unlocking the nervous system is your key to healing.”"
          }
        },
        {
          "type": "expert",
          "settings": {
            "name": "Nathalie Niddam",
            "role": "Certified Holistic Nutritionist",
            "quote": "“I've really been enjoying ZenBud - it helps me feel more focused and calm throughout the day.”"
          }
        }
      ]
    }
  ]
}
{% endschema %}