{% comment %}
  zenbud-experts.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100%;
    background-color: {{ section.settings.page_bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    overflow: hidden;
    display: block;
  }

  /* Background Image Layer */
  #shopify-section-{{ section.id }} .zenbud-experts__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    pointer-events: none;
    opacity: {{ section.settings.bg_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .zenbud-experts__container {
    position: relative;
    z-index: 2; /* Ensures the container sits above the background image */
    width: 75vw; /* 75% container width on desktop as requested */
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zenbud-experts__heading {
    font-size: 1.56vw; /* ~30px */
    font-weight: 300;
    color: {{ section.settings.heading_color }};
    margin: 0 0 7.5vw 0; /* ~100px */
    text-align: center;
  }

  #shopify-section-{{ section.id }} .zenbud-experts__grid {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    width: 100%;
    gap: 2.08vw; /* ~40px */
  }

  #shopify-section-{{ section.id }} .zenbud-experts__card {
    position: relative;
    flex: 1 1 0%;
    background-color: {{ section.settings.card_bg_color }};
    border-radius: 1.56vw; /* ~30px */
    width: 31%;
    box-shadow: 0 1.04vw 2.08vw rgba(0, 0, 0, 0.08);
    padding-bottom: 10vw;
    /* Intentionally omitting overflow: hidden so the image can break out the top */
  }

  /* The transparent PNG image */
  #shopify-section-{{ section.id }} .zenbud-experts__image {
    width: 100%;
    height: auto;
    /* Round the bottom corners to match the card, but leave the top flat to overflow */
    border-bottom-left-radius: 1.56vw;
    border-bottom-right-radius: 1.56vw;
    z-index: 1;
    pointer-events: none;
    object-fit: contain;
    object-position: bottom center;
    margin-top: -5vw;
  }

  /* The frosted glass / mirror overlay at the bottom */
  #shopify-section-{{ section.id }} .zenbud-experts__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    min-height: 42%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2.08vw 1.56vw;
    background-color: transparent;
    backdrop-filter: blur(1.56vw) brightness(0.15);
    -webkit-backdrop-filter: blur(1.56vw) brightness(0.15);
    border-radius: 1.56vw;
    overflow: hidden;
    z-index: 2;
    background: rgba(255,255,255,0.2);
  }

  /* White blur soft spots */
  #shopify-section-{{ section.id }} .zenbud-experts__spot {
    position: absolute;
    bottom: -5vw; /* ~-50px */
    width: 8.33vw; /* ~160px */
    height: 8.33vw; /* ~160px */
    background-color: rgba(25