{% comment %}
  zenbud-hsa-truemed.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    width: 100vw;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zbd-hsa-truemed__container {
    width: 90vw;
    max-width: 900px; /* Constrains line length for comfortable reading */
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Icon Styling */
  #shopify-section-{{ section.id }} .zbd-hsa-truemed__icon {
    width: {{ section.settings.icon_width }}px;
    height: auto;
    object-fit: contain;
    margin-bottom: 2.5vw;
  }

  #shopify-section-{{ section.id }} .zbd-hsa-truemed__heading {
    font-size: 2.5vw; /* ~48px */
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin: 0 0 2vw 0;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .zbd-hsa-truemed__text {
    font-size: 1.04vw; /* ~20px */
    line-height: 1.6;
    font-weight: 500;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    
    #shopify-section-{{ section.id }} .zbd-hsa-truemed__container {
      width: 90vw;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .zbd-hsa-truemed__icon {
      width: calc({{ section.settings.icon_width }}px * 0.8); /* Slightly smaller on mobile */
      margin-bottom: 6vw;
    }

    #shopify-section-{{ section.id }} .zbd-hsa-truemed__heading {
      font-size: 8vw;
      margin-bottom: 6vw;
    }

    #shopify-section-{{ section.id }} .zbd-hsa-truemed__text {
      font-size: 4.5vw;
    }
  }
</style>

<div class="zbd-hsa-truemed__container">
  
  {%- if section.settings.icon != blank -%}
    {{ section.settings.icon | image_url: width: 400 | image_tag: class: 'zbd-hsa-truemed__icon', loading: 'lazy', alt: section.settings.heading }}
  {%- endif -%}

  {%- if section.settings.heading != blank -%}
    <h2 class="zbd-hsa-truemed__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  {%- if section.settings.text != blank -%}
    <p class="zbd-hsa-truemed__text">{{ section.settings.text | escape }}</p>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "ZenBud HSA Truemed Info",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#111827"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 8.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 8.0
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Logo / Icon Image"
    },
    {
      "type": "range",
      "id": "icon_width",
      "min": 40,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Desktop Icon Width",
      "default": 80
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Who is Truemed?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text",
      "default": "At Truemed, we believe that investing in your health is far more valuable than waiting to spend on sickness. By unlocking pre-tax HSA/FSA spend on research backed interventions such as fitness, supplements, and health technology, we’re shifting healthcare spend toward true medicine."
    }
  ],
  "presets": [
    {
      "name": "ZenBud HSA Truemed Info",
      "category": "ZenBud HSA Page"
    }
  ]
}
{% endschema %}