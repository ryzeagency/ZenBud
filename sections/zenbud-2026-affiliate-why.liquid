{% comment %}
  zenbud-affiliate-why.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    width: 100vw;
    overflow: hidden;
    display: block;
  }

  #shopify-section-{{ section.id }} .zbd-aff-why__container {
    width: 85vw;
    max-width: 85vw;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4vw;
  }

  /* Left: Text Column */
  #shopify-section-{{ section.id }} .zbd-aff-why__text-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  #shopify-section-{{ section.id }} .zbd-aff-why__heading {
    font-size: 2.08vw; /* ~40px */
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 0 2vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-aff-why__text {
    font-size: 0.83vw; /* ~20px */
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin: 0 0 2vw 0;
  }

  /* List */
  #shopify-section-{{ section.id }} .zbd-aff-why__list {
    display: flex;
    flex-direction: column;
    gap: 1.25vw;
    margin: 0 0 2.5vw 0;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .zbd-aff-why__item {
    display: flex;
    align-items: flex-start;
    gap: 0.8vw;
  }

  #shopify-section-{{ section.id }} .zbd-aff-why__icon {
    width: 1.2vw;
    height: 1.2vw;
    flex-shrink: 0;
    margin-top: 0.3vw;
    color: {{ section.settings.accent_color }};
  }

  #shopify-section-{{ section.id }} .zbd-aff-why__item-text {
    font-size: 0.83vw; /* ~18px */
    line-height: 1.5;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  #shopify-section-{{ section.id }} .zbd-aff-why__item-text strong {
    color: #fff;
    font-weight: 700;
    display: block;
  }

  /* Footer Description */
  #shopify-section-{{ section.id }} .zbd-aff-why__footer-desc {
    font-size: 0.83vw;
    color: {{ section.settings.text_color }};
    margin-bottom: 2vw;
    opacity: 0.9;
  }

  /* Button */
  #shopify-section-{{ section.id }} .zbd-aff-why__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.accent_color }};
    color: #ffffff;
    border-radius: 2.6vw;
    padding: 0.93vw 2.5vw;
    font-size: 0.83vw;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    transition: opacity 0.3s ease;
  }

  /* Right: Image Column */
  #shopify-section-{{ section.id }} .zbd-aff-why__image-col {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .zbd-aff-why__image {
    width: 100%;
    max-width: 600px;
    height: auto;
    object-fit: contain;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: 15vw;
      padding-bottom: 15vw;
    }
    #shopify-section-{{ section.id }} .zbd-aff-why__container {
      flex-direction: column;
      width: 90vw;
      gap: 8vw;
    }
    #shopify-section-{{ section.id }} .zbd-aff-why__image-col { order: -1; }
    #shopify-section-{{ section.id }} .zbd-aff-why__heading { font-size: 7vw; margin-bottom: 6vw; }
    #shopify-section-{{ section.id }} .zbd-aff-why__text { font-size: 4vw; margin-bottom: 6vw; }
    #shopify-section-{{ section.id }} .zbd-aff-why__item { gap: 3vw; }
    #shopify-section-{{ section.id }} .zbd-aff-why__icon { width: 6vw; height: 6vw; }
    #shopify-section-{{ section.id }} .zbd-aff-why__item-text { font-size: 4vw; }
    #shopify-section-{{ section.id }} .zbd-aff-why__button { width: 100%; padding: 4vw; font-size: 4vw; border-radius: 8vw; }
  }
</style>

<div class="zbd-aff-why__container">
  <div class="zbd-aff-why__text-col">
    <h2 class="zbd-aff-why__heading">{{ section.settings.heading | escape }}</h2>
    <div class="zbd-aff-why__text">{{ section.settings.text }}</div>
    
    <div class="zbd-aff-why__list">
      {%- for block in section.blocks -%}
        <div class="zbd-aff-why__item">
          <svg class="zbd-aff-why__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          <div class="zbd-aff-why__item-text">{{ block.settings.item_text }}</div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_desc != blank -%}
      <p class="zbd-aff-why__footer-desc">{{ section.settings.footer_desc | escape }}</p>
    {%- endif -%}

    <a href="{{ section.settings.button_link }}" class="zbd-aff-why__button">{{ section.settings.button_label | escape }}</a>
  </div>

  <div class="zbd-aff-why__image-col">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'zbd-aff-why__image', loading: 'lazy' }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg zbd-aff-why__image' }}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "ZenBud Affiliate Why",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#000000" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Accent Color", "default": "#3A78F2" },
    { "type": "image_picker", "id": "image", "label": "Headphones Image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why ZenBud Works" },
    { "type": "richtext", "id": "text", "label": "Description" },
    { "type": "text", "id": "footer_desc", "label": "Footer Description", "default": "ZenBud gives biohackers the edge without wires, shocks, or side effects." },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "GET ZENBUD" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 15, "step": 0.5, "unit": "vw", "label": "Padding Top", "default": 5 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 15, "step": 0.5, "unit": "vw", "label": "Padding Bottom", "default": 5 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Feature Item",
      "settings": [ { "type": "richtext", "id": "item_text", "label": "Text" } ]
    }
  ],
  "presets": [ { "name": "ZenBud Affiliate Why",
      "blocks": [
        {
          "type": "item",
          "settings": { "item_text": "<p><strong>Want to Boost HRV Without Stimulants</strong><br>You track your HRV but rely on breathwork, supplements, or hacks to improve it. ZenBud naturally activates your vagus nerve to support better HRV in minutes — no pills, no stimulants.</p>" }
        },
        {
          "type": "item",
          "settings": { "item_text": "<p><strong>Look for Ways to Accelerate Recovery Through Nervous System Training</strong></p>" }
        },
        {
          "type": "item",
          "settings": { "item_text": "<p><strong>Struggle to Lower Cortisol or Enter a Calm, Focused State</strong></p>" }
        },
        {
          "type": "item",
          "settings": { "item_text": "<p><strong>Prefer Clean, Silent Tech That's Backed by Science</strong></p>" }
        }
      ]
  } ]
}
{% endschema %}