{% comment %}
  zenbud-science-info.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    width: 100vw;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    overflow: hidden;
    display: block;
  }

  #shopify-section-{{ section.id }} .zbd-sci-info__container {
    width: 85vw;
    max-width: 85vw; /* ~1440px */
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 6vw;
  }

  /* Swaps the column order if set to left */
  #shopify-section-{{ section.id }} .zbd-sci-info__container--reverse {
    flex-direction: row-reverse;
  }

  /* Left: Text Content Column */
  #shopify-section-{{ section.id }} .zbd-sci-info__text-col {
    flex: 1.2;
    display: flex;
    flex-direction: column;
    gap: 3.12vw; /* ~60px between blocks */
  }

  #shopify-section-{{ section.id }} .zbd-sci-info__block {
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .zbd-sci-info__heading {
    font-size: 1.66vw; /* ~32px */
    font-weight: 500;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1vw 0;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .zbd-sci-info__content {
    font-size: 0.93vw; /* ~18px */
    line-height: 1.6;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .zbd-sci-info__content p {
    margin: 0 0 1.5vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-sci-info__content p:last-child {
    margin-bottom: 0;
  }

  /* Right: Image Column */
  #shopify-section-{{ section.id }} .zbd-sci-info__img-col {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .zbd-sci-info__img-col img {
    width: 100%;
    height: auto;
    max-width: 35vw; /* Constrains image size */
    object-fit: contain;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    
    #shopify-section-{{ section.id }} .zbd-sci-info__container,
    #shopify-section-{{ section.id }} .zbd-sci-info__container--reverse {
      flex-direction: column-reverse; /* Always stacks image on top of text on mobile */
      width: 90vw;
      max-width: 100%;
      gap: 10vw;
    }

    #shopify-section-{{ section.id }} .zbd-sci-info__img-col img {
      max-width: 80vw;
    }

    #shopify-section-{{ section.id }} .zbd-sci-info__text-col {
      width: 100%;
      gap: 8vw;
    }

    #shopify-section-{{ section.id }} .zbd-sci-info__heading {
      font-size: 6.5vw;
      margin-bottom: 3vw;
    }

    #shopify-section-{{ section.id }} .zbd-sci-info__content {
      font-size: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-sci-info__content p {
      margin-bottom: 4vw;
    }
  }
</style>

<div class="zbd-sci-info__container {% if section.settings.image_position == 'left' %}zbd-sci-info__container--reverse{% endif %}">
  
  <div class="zbd-sci-info__text-col">
    {%- for block in section.blocks -%}
      <div class="zbd-sci-info__block" {{ block.shopify_attributes }}>
        {%- if block.settings.heading != blank -%}
          <h3 class="zbd-sci-info__heading">{{ block.settings.heading | escape }}</h3>
        {%- endif -%}
        
        {%- if block.settings.content != blank -%}
          <div class="zbd-sci-info__content">
            {{ block.settings.content }}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  <div class="zbd-sci-info__img-col">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.image.alt | default: 'Science Image' }}
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "ZenBud Science Info",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#4A4A4A"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Desktop Image Position",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "right"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 8.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 8.0
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Text Block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Vagus Nerve 101"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Your vagus nerve is one of the most important communication highways in your body.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZenBud Science Info",
      "category": "Zenbud Science",
      "blocks": [
        {
          "type": "text_block",
          "settings": {
            "heading": "Vagus Nerve 101",
            "content": "<p>Your vagus nerve is one of the most important communication highways in your body.</p><p>It runs from your brainstem through your face, neck, heart, and digestive system—connecting nearly every major organ to your brain.</p><p>It's part of your parasympathetic nervous system, sometimes called the \"rest and digest\" system. When activated, it lowers heart rate, reduces cortisol (your stress hormone), and helps your body shift from fight-or-flight to rest-and-recover.</p>"
          }
        },
        {
          "type": "text_block",
          "settings": {
            "heading": "When Stress Takes Over",
            "content": "<p>Under constant stress, the vagus nerve can become underactive. That's when people experience symptoms like racing thoughts, poor sleep, tightness in the chest, or a sense of being \"stuck\" in overdrive.</p><p>Traditional stress management methods—like deep breathing, meditation, or humming—actually work because they manually stimulate the vagus nerve. ZenBud takes that same biological principle and amplifies it through precise, non-electrical technology.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}