    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading & Title Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#C4C4C4"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Subheading & Button)",
      "default": "#2E62DB"
    },
    {
      "type": "header",
      "content": "Video Background"
    },
    {
      "type": "video",
      "id": "bg_video",
      "label": "Background Video",
      "info": "Upload an MP4. The video will scrub forwards and backwards as the user scrolls."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "ABOUT THE DEVICE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything Your Nervous System Needs"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "GET ZENBUD"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
