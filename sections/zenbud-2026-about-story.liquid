{% comment %}
  zenbud-about-story.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    width: 100vw;
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}vw;
    padding-bottom: {{ section.settings.padding_bottom }}vw;
    /* Visible allows the image to break out top and bottom without getting cropped */
    overflow: visible; 
    z-index: 2; 
    display: block;
  }

  /* Background Image Layer */
  #shopify-section-{{ section.id }} .zbd-about-story__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    pointer-events: none;
    opacity: {{ section.settings.bg_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .zbd-about-story__container {
    position: relative;
    z-index: 2;
    width: 85vw;
    max-width: 85vw; /* ~1440px */
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    align-items: center;
  }

  /* Left: Text Column */
  #shopify-section-{{ section.id }} .zbd-about-story__text-col {
    flex: 1.5;
    position: relative;
    z-index: 2;
  }

  /* White Mirror Glass Card */
  #shopify-section-{{ section.id }} .zbd-about-story__glass-card {
    background: rgba(255, 255, 255, 0.15); /* Light frosted tint */
    backdrop-filter: blur(24px) brightness(1.1);
    -webkit-backdrop-filter: blur(24px) brightness(1.1);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 2vw; /* ~38px */
    
    /* Extra right padding ensures the text isn't covered by the overlapping image */
    padding: 4vw 10vw 4vw 4vw; 
    
    color: #ffffff;
    box-shadow: 0 1vw 3vw rgba(0, 0, 0, 0.05);
  }

  #shopify-section-{{ section.id }} .zbd-about-story__heading {
    font-size: 2.08vw; /* ~40px */
    font-weight: 400;
    color: #ffffff;
    margin: 0 0 1.5vw 0;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .zbd-about-story__intro {
    font-size: 1.04vw; /* ~20px */
    line-height: 1.5;
    color: #ffffff;
    margin: 0 0 1.5vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-about-story__text {
    font-size: 0.93vw; /* ~18px */
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
  }

  #shopify-section-{{ section.id }} .zbd-about-story__text p {
    margin: 0 0 1.5vw 0;
  }

  #shopify-section-{{ section.id }} .zbd-about-story__text p:last-child {
    margin-bottom: 0;
  }

  /* Right: Image Column */
  #shopify-section-{{ section.id }} .zbd-about-story__img-col {
    flex: 1;
    position: relative;
    z-index: 3; /* Forces image to sit ON TOP of the glass card */
  }

  #shopify-section-{{ section.id }} .zbd-about-story__img-col img {
    width: 140%; /* Scaled up to overflow */
    max-width: none;
    height: auto;
    object-fit: contain;
    
    /* THE MAGIC MARGINS: Breaks top, bottom, and pushes left into the card */
    margin-top: -12%; 
    margin-bottom: -12%;
    margin-left: -25%; 
    
    filter: drop-shadow(-1vw 2vw 3vw rgba(0,0,0,0.15));
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} {
      padding-top: calc({{ section.settings.padding_top }}vw * 3);
      padding-bottom: calc({{ section.settings.padding_bottom }}vw * 3);
    }
    
    #shopify-section-{{ section.id }} .zbd-about-story__container {
      flex-direction: column;
      width: 90vw;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .zbd-about-story__text-col {
      width: 100%;
      order: 2;
    }

    #shopify-section-{{ section.id }} .zbd-about-story__glass-card {
      padding: 15vw 6vw 8vw 6vw; /* Massive top padding to clear the image overlap */
      border-radius: 6vw;
      backdrop-filter: blur(16px) brightness(1.1);
      -webkit-backdrop-filter: blur(16px) brightness(1.1);
    }

    #shopify-section-{{ section.id }} .zbd-about-story__heading {
      font-size: 7vw;
      margin-bottom: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-about-story__intro {
      font-size: 4.5vw;
      margin-bottom: 4vw;
    }

    #shopify-section-{{ section.id }} .zbd-about-story__text {
      font-size: 4vw;
    }
    
    #shopify-section-{{ section.id }} .zbd-about-story__text p {
      margin-bottom: 5vw;
    }

    #shopify-section-{{ section.id }} .zbd-about-story__img-col {
      width: 100%;
      order: 1;
      display: flex;
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .zbd-about-story__img-col img {
      width: 110%;
      margin-top: -15%; /* Hangs out top */
      margin-left: 0;
      margin-bottom: -20%; /* Pulls the glass card up underneath it */
    }
  }
</style>

{%- if section.settings.bg_image != blank -%}
  {{ section.settings.bg_image | image_url: width: 2400 | image_tag: class: 'zbd-about-story__bg', loading: 'lazy', alt: 'Background Wave' }}
{%- endif -%}

<div class="zbd-about-story__container">
  
  <div class="zbd-about-story__text-col">
    <div class="zbd-about-story__glass-card">
      
      {%- if section.settings.heading != blank -%}
        <h2 class="zbd-about-story__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.intro != blank -%}
        <div class="zbd-about-story__intro">
          {{ section.settings.intro }}
        </div>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="zbd-about-story__text">
          {{ section.settings.text }}
        </div>
      {%- endif -%}

    </div>
  </div>

  <div class="zbd-about-story__img-col">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'ZenBud Story' }}
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "ZenBud About Story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#3A78F2"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image (Optional Wave)"
    },
    {
      "type": "range",
      "id": "bg_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Image Opacity",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Top (Desktop)",
      "default": 6.0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "unit": "vw",
      "label": "Padding Bottom (Desktop)",
      "default": 6.0
    },
    {
      "type": "header",
      "content": "Glass Card Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Calm-Through-Science Became a Modern Wellness Brand"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro Paragraph",
      "default": "<p>ZenBud began with a simple question: what if everyday calm could be designed?</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text",
      "default": "<p>We believed technology could nurture both body and mind—without drugs, wearables fuss, or complex routines. Today, that belief lives in the ZenBud device: a non-invasive blend of ultrasound stimulation and VSN (vibro-sensory neuromodulation) that supports relaxation, focus, and restorative sleep—naturally.</p>"
    },
    {
      "type": "header",
      "content": "Right Side Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Overlapping Image",
      "info": "This image will automatically break out of the section's top/bottom bounds and overlap the glass card."
    }
  ],
  "presets": [
    {
      "name": "ZenBud About Story",
      "category": "ZenBud About"
    }
  ]
}
{% endschema %}