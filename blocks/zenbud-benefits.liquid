<style>
  .zbd-benefits-wrap-{{ block.id }} {
    margin: 1.5rem 0;
  }
  .zbd-benefits-list-{{ block.id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .zbd-benefits-list-{{ block.id }} li {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.4rem; /* Adjust to match your theme's base size */
    color: inherit;
    line-height: 1.3;
  }
  .zbd-benefits-icon-{{ block.id }} {
    width: 1.8rem;
    height: 1.8rem;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
  }
</style>

<div class="zbd-benefits-wrap-{{ block.id }}" {{ block.shopify_attributes }}>
  <ul class="zbd-benefits-list-{{ block.id }}">
    {%- for i in (1..5) -%}
      {%- assign text_key = 'benefit_' | append: i -%}
      {%- assign text_val = block.settings[text_key] -%}
      
      {%- if text_val != blank -%}
        <li>
          <svg class="zbd-benefits-icon-{{ block.id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="10" stroke-width="1.5"/>
            <path d="M8 12L11 15L16 9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {{ text_val | escape }}
        </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>
</div>

{% schema %}
{
  "name": "ZenBud Benefits List",
  "settings": [
    {
      "type": "color",
      "id": "icon_color",
      "label": "Checkmark Color",
      "default": "#3A78F2"
    },
    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefit 1",
      "default": "90-day money-back guarantee"
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefit 2",
      "default": "1-year manufacturer warranty"
    },
    {
      "type": "text",
      "id": "benefit_3",
      "label": "Benefit 3",
      "default": "Free travel case & silicone pads"
    },
    {
      "type": "text",
      "id": "benefit_4",
      "label": "Benefit 4",
      "default": "Free 7-day trial for BreathSource"
    },
    {
      "type": "text",
      "id": "benefit_5",
      "label": "Benefit 5"
    }
  ],
  "presets": [
    {
      "name": "ZenBud Benefits List"
    }
  ]
}
{% endschema %}