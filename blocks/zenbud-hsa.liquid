<style>
  .product-information .truemed-entry-text {
      font-size: 14px;
  }
  .zbd-hsa-wrap-{{ block.id }} {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-size: 0.75vw;
    color: inherit;
    line-height: 1.4;
  }
  .zbd-hsa-title-{{ block.id }} {
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .zbd-hsa-icon-{{ block.id }} {
    width: 1.4rem;
    height: 1.4rem;
    opacity: 0.6;
  }
  .zbd-hsa-subtitle-{{ block.id }} {
    font-weight: 400;
    opacity: 0.8;
  }
  .zbd-hsa-link-{{ block.id }} {
    text-decoration: underline;
    font-weight: 600;
    color: inherit;
    cursor: pointer;
    opacity: 0.9;
    transition: opacity 0.2s;
  }
  .zbd-hsa-link-{{ block.id }}:hover {
    opacity: 1;
  }
  @media screen and (max-width: 767px) {
    .zbd-hsa-wrap-{{ block.id }} {
      font-size: 14px;
    }
    .product-information .truemed-entry-text {
        font-size: 12px;
    }
  }
</style>

<div class="zbd-hsa-wrap-{{ block.id }}" {{ block.shopify_attributes }}>

  <div id="truemed-instructions"style="font-size: 16px; margin-top: 7px; margin-bottom: 10px; font-family: Poppins, sans-serif;" icon-height="12" data-public-id="tm_qual_1v8w4fnt2l"></div>
  <script src="https://static.truemed.com/widgets/product-page-widget.min.js" defer></script>

</div>

{% schema %}
{
  "name": "ZenBud HSA/FSA",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Bold Title",
      "default": "HSA/FSA eligible"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtext",
      "default": "Save an average of 30%"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "ZenBud HSA/FSA"
    }
  ]
}
{% endschema %}