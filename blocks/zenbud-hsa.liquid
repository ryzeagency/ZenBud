<style>
  .zbd-hsa-wrap-{{ block.id }} {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-size: 0.75vw;
    color: inherit;
    line-height: 1.4;
  }
  .zbd-hsa-title-{{ block.id }} {
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .zbd-hsa-icon-{{ block.id }} {
    width: 1.4rem;
    height: 1.4rem;
    opacity: 0.6;
  }
  .zbd-hsa-subtitle-{{ block.id }} {
    font-weight: 400;
    opacity: 0.8;
  }
  .zbd-hsa-link-{{ block.id }} {
    text-decoration: underline;
    font-weight: 600;
    color: inherit;
    cursor: pointer;
    opacity: 0.9;
    transition: opacity 0.2s;
  }
  .zbd-hsa-link-{{ block.id }}:hover {
    opacity: 1;
  }
  @media screen and (max-width: 767px) {
    .zbd-hsa-wrap-{{ block.id }} {
      font-size: 14px;
    }
  }
</style>

<div class="zbd-hsa-wrap-{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="zbd-hsa-title-{{ block.id }}">
    {{ block.settings.title | escape }}
    <svg class="zbd-hsa-icon-{{ block.id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 16V12M12 8H12.01" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </div>
  
  <span class="zbd-hsa-subtitle-{{ block.id }}">{{ block.settings.subtitle | escape }}</span>
  
  {%- if block.settings.link_text != blank -%}
    <a href="{{ block.settings.link }}" class="zbd-hsa-link-{{ block.id }}">{{ block.settings.link_text | escape }}</a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "ZenBud HSA/FSA",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Bold Title",
      "default": "HSA/FSA eligible"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtext",
      "default": "Save an average of 30%"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "ZenBud HSA/FSA"
    }
  ]
}
{% endschema %}